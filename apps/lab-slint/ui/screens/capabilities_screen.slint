import { Theme } from "../theme.slint";
import { Strings } from "../strings.slint";
import { PanelCard } from "../components/panel_card.slint";
import { EmptyState } from "../components/empty_state.slint";
import { StatusBadge } from "../components/status_badge.slint";

export component CapabilitiesScreen inherits Rectangle {
    in-out property <[string]> capability-ids: [];
    in-out property <[string]> capability-statuses: [];
    in-out property <[string]> capability-notes: [];

    background: transparent;
    property <bool> has-rows: capability-ids.length > 0;

    if !has-rows: EmptyState {
        title: Strings.nav-capabilities;
        body: Strings.empty-hint-capabilities;
        show-cta: false;
    }

    if has-rows: VerticalLayout {
        padding: Theme.main-pad;
        spacing: 12px;
        Text {
            text: Strings.nav-capabilities;
            color: Theme.text-secondary;
            font-size: 11px;
            font-weight: 800;
            letter-spacing: 0.5px;
        }
        PanelCard {
            vertical-stretch: 1;
            VerticalLayout {
                padding: 12px;
                Flickable {
                    vertical-stretch: 1;
                    viewport-width: parent.width - 24px;
                    VerticalLayout {
                        spacing: 4px;
                        width: parent.width - 24px;
                        for i in capability-ids.length: Rectangle {
                            height: Theme.row-height + 8px;
                            border-radius: Theme.chip-radius;
                            background: Theme.surface;
                            HorizontalLayout {
                                padding-left: 8px;
                                padding-right: 8px;
                                spacing: 10px;
                                Text {
                                    text: capability-ids[i];
                                    color: Theme.text-primary;
                                    font-size: 12px;
                                    font-weight: 600;
                                    vertical-alignment: center;
                                    min-width: 120px;
                                }
                                StatusBadge {
                                    label: capability-statuses[i];
                                    kind: capability-statuses[i] == "Validated" || capability-statuses[i] == "OK" ? "ok"
                                        : capability-statuses[i] == "Partial" || capability-statuses[i] == "Warn" ? "warn"
                                        : capability-statuses[i] == "Fail" || capability-statuses[i] == "Failed" ? "danger"
                                        : "info";
                                }
                                Text {
                                    text: capability-notes[i];
                                    color: Theme.text-secondary;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                    overflow: elide;
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
