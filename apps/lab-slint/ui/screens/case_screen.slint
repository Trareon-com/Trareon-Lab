import { Button } from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { Strings } from "../strings.slint";
import { SectionCard } from "../components/section_card.slint";
import { MetricTile } from "../components/metric_tile.slint";
import { LabButton } from "../components/lab_button.slint";
import { StatusBadge } from "../components/status_badge.slint";

export component PlaceTile inherits Rectangle {
    in-out property <string> label;
    in-out property <bool> enabled: true;
    callback clicked();

    height: 36px;
    border-radius: 4px;
    border-width: 1px;
    border-color: Theme.border;
    background: Theme.surface-raised;
    opacity: enabled ? 1.0 : 0.45;

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        Text {
            text: root.label;
            color: Theme.text-primary;
            font-size: 12px;
            vertical-alignment: center;
            overflow: elide;
        }
    }

    ta := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }
    states [
        hover when ta.has-hover && root.enabled: { background: Theme.row-hover; }
    ]
}

export component CaseScreen inherits Rectangle {
    in-out property <string> case-title;
    in-out property <string> case-state-label: "open";
    in-out property <int> evidence-count;
    in-out property <int> coverage-count;
    in-out property <int> bookmark-count;
    in-out property <string> about-line;
    callback open-case-clicked();
    callback import-evidence-clicked();
    callback navigate(string);

    background: transparent;
    property <bool> body-wide: self.width >= 900px;

    open-btn := Button {
        x: -10000px;
        y: -10000px;
        width: 1px;
        height: 1px;
        text: Strings.open-case;
        primary: true;
        clicked => { root.open-case-clicked(); }
    }

    public function focus-open() {
        open-btn.focus();
    }

    if body-wide: HorizontalLayout {
        padding: 12px;
        spacing: 12px;
        case-col := VerticalLayout {
            horizontal-stretch: 1;
            SectionCard {
                title: Strings.case-overview;
                VerticalLayout {
                    spacing: 12px;
                    Text {
                        text: root.case-title;
                        color: Theme.mono-fg;
                        font-family: "monospace";
                        font-size: 13px;
                        wrap: word-wrap;
                    }
                    StatusBadge {
                        label: root.case-state-label;
                        kind: "info";
                    }
                    LabButton {
                        primary: true;
                        label: Strings.open-case;
                        clicked => { root.open-case-clicked(); }
                    }
                    Text {
                        text: Strings.about-prefix + ": " + root.about-line;
                        color: Theme.text-secondary;
                        font-size: 11px;
                        wrap: word-wrap;
                    }
                }
            }
        }
        evidence-col := VerticalLayout {
            horizontal-stretch: 1;
            SectionCard {
                title: Strings.evidence-overview;
                VerticalLayout {
                    spacing: 10px;
                    MetricTile {
                        label: Strings.status-evidence;
                        value: root.evidence-count;
                    }
                    MetricTile {
                        label: Strings.status-coverage;
                        value: root.coverage-count;
                    }
                    LabButton {
                        primary: false;
                        label: Strings.import-evidence;
                        clicked => { root.import-evidence-clicked(); }
                    }
                }
            }
        }
        places-col := VerticalLayout {
            horizontal-stretch: 1;
            SectionCard {
                title: Strings.places-to-start;
                VerticalLayout {
                    spacing: 8px;
                    PlaceTile {
                        label: Strings.go-evidence;
                        enabled: root.evidence-count > 0;
                        clicked => { root.navigate("Evidence"); }
                    }
                    PlaceTile {
                        label: Strings.go-search;
                        clicked => { root.navigate("Search"); }
                    }
                    PlaceTile {
                        label: Strings.go-timeline;
                        clicked => { root.navigate("Timeline"); }
                    }
                    PlaceTile {
                        label: Strings.go-bookmarks;
                        enabled: root.bookmark-count > 0;
                        clicked => { root.navigate("Bookmarks"); }
                    }
                    PlaceTile {
                        label: Strings.go-report;
                        clicked => { root.navigate("Report"); }
                    }
                }
            }
        }
    }

    if !body-wide: Flickable {
        viewport-width: parent.width;
        VerticalLayout {
            padding: 12px;
            spacing: 12px;
            width: parent.width;
            SectionCard {
                title: Strings.case-overview;
                VerticalLayout {
                    spacing: 12px;
                    Text {
                        text: root.case-title;
                        color: Theme.mono-fg;
                        font-family: "monospace";
                        font-size: 13px;
                        wrap: word-wrap;
                    }
                    StatusBadge { label: root.case-state-label; kind: "info"; }
                    LabButton {
                        primary: true;
                        label: Strings.open-case;
                        clicked => { root.open-case-clicked(); }
                    }
                }
            }
            SectionCard {
                title: Strings.evidence-overview;
                VerticalLayout {
                    spacing: 10px;
                    MetricTile { label: Strings.status-evidence; value: root.evidence-count; }
                    MetricTile { label: Strings.status-coverage; value: root.coverage-count; }
                    LabButton {
                        primary: false;
                        label: Strings.import-evidence;
                        clicked => { root.import-evidence-clicked(); }
                    }
                }
            }
            SectionCard {
                title: Strings.places-to-start;
                VerticalLayout {
                    spacing: 8px;
                    PlaceTile { label: Strings.go-evidence; enabled: root.evidence-count > 0; clicked => { root.navigate("Evidence"); } }
                    PlaceTile { label: Strings.go-search; clicked => { root.navigate("Search"); } }
                    PlaceTile { label: Strings.go-timeline; clicked => { root.navigate("Timeline"); } }
                    PlaceTile { label: Strings.go-bookmarks; enabled: root.bookmark-count > 0; clicked => { root.navigate("Bookmarks"); } }
                    PlaceTile { label: Strings.go-report; clicked => { root.navigate("Report"); } }
                }
            }
        }
    }
}
