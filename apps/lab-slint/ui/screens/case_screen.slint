import { Button } from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { Strings } from "../strings.slint";
import { SectionCard } from "../components/section_card.slint";
import { MetricTile } from "../components/metric_tile.slint";
import { LabButton } from "../components/lab_button.slint";
import { StatusBadge } from "../components/status_badge.slint";

export component PlaceTile inherits Rectangle {
    in-out property <string> label;
    in-out property <bool> enabled: true;
    callback clicked();

    height: 40px;
    border-radius: 5px;
    border-width: 1px;
    border-color: Theme.border;
    background: Theme.surface;
    opacity: enabled ? 1.0 : 0.4;

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 8px;
        Text {
            text: root.label;
            color: root.enabled ? Theme.text-primary : Theme.text-secondary;
            font-size: 13px;
            vertical-alignment: center;
            horizontal-stretch: 1;
            overflow: elide;
        }
        Text {
            text: "›";
            color: Theme.text-secondary;
            font-size: 16px;
            vertical-alignment: center;
        }
    }

    ta := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }
    states [
        hover when ta.has-hover && root.enabled: {
            background: Theme.row-hover;
            border-color: Theme.accent-muted;
        }
    ]
}

export component CaseScreen inherits Rectangle {
    in-out property <string> case-title;
    in-out property <string> case-state-label: "open";
    in-out property <int> evidence-count;
    in-out property <int> coverage-count;
    in-out property <int> bookmark-count;
    in-out property <[string]> activity-lines;
    callback open-case-clicked();
    callback import-evidence-clicked();
    callback navigate(string);

    background: transparent;
    property <bool> has-case: case-title != "" && case-title != "(no case)";
    property <int> stage: !has-case ? 0
        : evidence-count <= 0 ? 1
        : bookmark-count > 0 ? 3
        : 2;
    property <string> next-body: stage == 0 ? Strings.next-open
        : stage == 1 ? Strings.next-import
        : stage == 3 ? Strings.next-report
        : Strings.next-examine;
    property <string> next-cta: stage == 0 ? Strings.open-case
        : stage == 1 ? Strings.import-evidence
        : stage == 3 ? Strings.go-report
        : Strings.browse-evidence;

    open-btn := Button {
        x: -10000px;
        y: -10000px;
        width: 1px;
        height: 1px;
        text: Strings.open-case;
        primary: true;
        clicked => { root.open-case-clicked(); }
    }

    public function focus-open() {
        open-btn.focus();
    }

    // Empty: one composition — brand, line, CTA. No empty-card dashboard.
    if !has-case: Rectangle {
        width: 100%;
        height: 100%;
        background: Theme.canvas;

        welcome-plate := Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: min(520px, max(320px, parent.width - 80px));
            height: 340px;
            background: Theme.surface;
            border-width: 1px;
            border-color: Theme.border;
            border-radius: 8px;

            VerticalLayout {
                padding: 36px;
                spacing: 0px;

                HorizontalLayout {
                    alignment: center;
                    spacing: 12px;
                    Rectangle {
                        width: 12px;
                        height: 12px;
                        border-radius: 2px;
                        background: Theme.accent;
                    }
                    Text {
                        text: Strings.brand;
                        color: Theme.text-primary;
                        font-size: 26px;
                        font-weight: 700;
                        vertical-alignment: center;
                    }
                }

                Rectangle { height: 20px; }

                Text {
                    text: Strings.welcome-headline;
                    color: Theme.text-primary;
                    font-size: 17px;
                    font-weight: 600;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }

                Rectangle { height: 12px; }

                Text {
                    text: Strings.welcome-body;
                    color: Theme.text-secondary;
                    font-size: 13px;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }

                Rectangle { height: 28px; }

                HorizontalLayout {
                    alignment: center;
                    LabButton {
                        primary: true;
                        label: Strings.open-case;
                        clicked => { root.open-case-clicked(); }
                    }
                }

                Rectangle { height: 22px; }

                Rectangle {
                    height: 1px;
                    background: Theme.border;
                }

                Rectangle { height: 16px; }

                Text {
                    text: Strings.welcome-meta;
                    color: Theme.mono-fg;
                    font-family: "monospace";
                    font-size: 11px;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }
            }
        }
    }

    // Case open: dense workstation funnel.
    if has-case: VerticalLayout {
        padding: 16px;
        spacing: 14px;

        Rectangle {
            background: Theme.surface;
            border-width: 1px;
            border-color: Theme.border;
            border-radius: 6px;
            VerticalLayout {
                padding: 16px;
                spacing: 12px;
                HorizontalLayout {
                    spacing: 12px;
                    VerticalLayout {
                        spacing: 6px;
                        horizontal-stretch: 1;
                        Text {
                            text: Strings.next-action;
                            color: Theme.text-secondary;
                            font-size: 11px;
                            font-weight: 700;
                        }
                        Text {
                            text: root.next-body;
                            color: Theme.text-primary;
                            font-size: 15px;
                            font-weight: 600;
                            wrap: word-wrap;
                        }
                        Text {
                            text: root.case-title;
                            color: Theme.mono-fg;
                            font-family: "monospace";
                            font-size: 12px;
                            wrap: word-wrap;
                        }
                    }
                    StatusBadge {
                        label: root.case-state-label;
                        kind: "ok";
                    }
                }
                HorizontalLayout {
                    spacing: 8px;
                    alignment: start;
                    LabButton {
                        primary: true;
                        label: root.next-cta;
                        clicked => {
                            if root.stage == 1 {
                                root.import-evidence-clicked();
                            } else if root.stage == 3 {
                                root.navigate("Report");
                            } else {
                                root.navigate("Evidence");
                            }
                        }
                    }
                    if root.stage == 1: LabButton {
                        primary: false;
                        label: Strings.open-case;
                        clicked => { root.open-case-clicked(); }
                    }
                    if root.stage >= 2: LabButton {
                        primary: false;
                        label: Strings.go-search;
                        clicked => { root.navigate("Search"); }
                    }
                    if root.stage >= 2: LabButton {
                        primary: false;
                        label: Strings.go-timeline;
                        clicked => { root.navigate("Timeline"); }
                    }
                }
            }
        }

        HorizontalLayout {
            spacing: 12px;
            vertical-stretch: 1;

            SectionCard {
                title: Strings.evidence-overview;
                horizontal-stretch: 1;
                VerticalLayout {
                    spacing: 8px;
                    MetricTile {
                        label: Strings.status-evidence;
                        value: root.evidence-count;
                    }
                    MetricTile {
                        label: Strings.status-coverage;
                        value: root.coverage-count;
                    }
                    MetricTile {
                        label: Strings.status-bookmarks;
                        value: root.bookmark-count;
                    }
                    Rectangle { height: 4px; }
                    HorizontalLayout {
                        alignment: start;
                        LabButton {
                            primary: root.evidence-count == 0;
                            label: Strings.import-evidence;
                            clicked => { root.import-evidence-clicked(); }
                        }
                    }
                }
            }

            SectionCard {
                title: Strings.examine-now;
                horizontal-stretch: 1;
                VerticalLayout {
                    spacing: 8px;
                    PlaceTile {
                        label: Strings.go-evidence;
                        enabled: root.evidence-count > 0;
                        clicked => { root.navigate("Evidence"); }
                    }
                    PlaceTile {
                        label: Strings.go-search;
                        clicked => { root.navigate("Search"); }
                    }
                    PlaceTile {
                        label: Strings.go-timeline;
                        clicked => { root.navigate("Timeline"); }
                    }
                    PlaceTile {
                        label: Strings.go-bookmarks;
                        enabled: root.bookmark-count > 0;
                        clicked => { root.navigate("Bookmarks"); }
                    }
                    PlaceTile {
                        label: Strings.go-report;
                        clicked => { root.navigate("Report"); }
                    }
                }
            }

            SectionCard {
                title: Strings.activity;
                horizontal-stretch: 1;
                if root.activity-lines.length == 0: Text {
                    text: Strings.activity-empty;
                    color: Theme.text-secondary;
                    font-size: 12px;
                    wrap: word-wrap;
                }
                if root.activity-lines.length > 0: VerticalLayout {
                    spacing: 8px;
                    for line[idx] in root.activity-lines: HorizontalLayout {
                        spacing: 8px;
                        Rectangle {
                            width: 6px;
                            height: 6px;
                            y: 5px;
                            border-radius: 1px;
                            background: idx == 0 ? Theme.accent : Theme.border;
                        }
                        Text {
                            text: line;
                            color: idx == 0 ? Theme.text-primary : Theme.mono-fg;
                            font-family: "monospace";
                            font-size: 11px;
                            wrap: word-wrap;
                            horizontal-stretch: 1;
                        }
                    }
                }
            }
        }
    }
}
