import { Button } from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { Strings } from "../strings.slint";
import { LabButton } from "../components/lab_button.slint";
import { StatusBadge } from "../components/status_badge.slint";

export component CaseScreen inherits Rectangle {
    in-out property <string> case-title;
    in-out property <string> case-state-label: "open";
    in-out property <int> evidence-count;
    in-out property <int> coverage-count;
    in-out property <int> bookmark-count;
    in-out property <[string]> activity-lines;
    callback open-case-clicked();
    callback import-evidence-clicked();
    callback navigate(string);

    background: transparent;
    property <bool> has-case: case-title != "" && case-title != "(no case)";
    property <int> stage: !has-case ? 0
        : evidence-count <= 0 ? 1
        : bookmark-count > 0 ? 3
        : 2;
    property <string> next-body: stage == 0 ? Strings.next-open
        : stage == 1 ? Strings.next-import
        : stage == 3 ? Strings.next-report
        : Strings.next-examine;
    property <string> next-cta: stage == 0 ? Strings.open-case
        : stage == 1 ? Strings.import-evidence
        : stage == 3 ? Strings.go-report
        : Strings.browse-evidence;

    open-btn := Button {
        x: -10000px;
        y: -10000px;
        width: 1px;
        height: 1px;
        text: Strings.open-case;
        primary: true;
        clicked => { root.open-case-clicked(); }
    }

    public function focus-open() {
        open-btn.focus();
    }

    if !has-case: Rectangle {
        width: 100%;
        height: 100%;
        background: Theme.canvas;
        welcome-plate := Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: min(480px, max(300px, parent.width - 64px));
            height: 300px;
            background: Theme.surface;
            border-width: 1px;
            border-color: Theme.border;
            border-radius: 6px;
            VerticalLayout {
                padding: 28px;
                spacing: 0px;
                HorizontalLayout {
                    alignment: center;
                    spacing: 10px;
                    Rectangle {
                        width: 10px;
                        height: 10px;
                        border-radius: 2px;
                        background: Theme.accent;
                    }
                    Text {
                        text: Strings.brand;
                        color: Theme.text-primary;
                        font-size: 22px;
                        font-weight: 700;
                        vertical-alignment: center;
                    }
                }
                Rectangle { height: 14px; }
                Text {
                    text: Strings.welcome-headline;
                    color: Theme.text-primary;
                    font-size: 14px;
                    font-weight: 600;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }
                Rectangle { height: 8px; }
                Text {
                    text: Strings.welcome-body;
                    color: Theme.text-secondary;
                    font-size: 12px;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }
                Rectangle { height: 20px; }
                HorizontalLayout {
                    alignment: center;
                    LabButton {
                        primary: true;
                        label: Strings.open-case;
                        clicked => { root.open-case-clicked(); }
                    }
                }
                Rectangle { height: 16px; }
                Text {
                    text: Strings.welcome-meta;
                    color: Theme.mono-fg;
                    font-family: "monospace";
                    font-size: 11px;
                    horizontal-alignment: center;
                }
            }
        }
    }

    // Dense strip — tool, not dashboard.
    if has-case: VerticalLayout {
        padding: 8px;
        spacing: 8px;

        Rectangle {
            background: Theme.surface;
            border-width: 1px;
            border-color: Theme.border;
            border-radius: 4px;
            VerticalLayout {
                padding: 10px;
                spacing: 8px;
                HorizontalLayout {
                    spacing: 8px;
                    Text {
                        text: root.next-body;
                        color: Theme.text-primary;
                        font-size: 13px;
                        font-weight: 600;
                        wrap: word-wrap;
                        horizontal-stretch: 1;
                        vertical-alignment: center;
                    }
                    StatusBadge {
                        label: root.case-state-label;
                        kind: "ok";
                    }
                }
                Text {
                    text: root.case-title;
                    color: Theme.mono-fg;
                    font-family: "monospace";
                    font-size: 11px;
                }
                HorizontalLayout {
                    spacing: 6px;
                    LabButton {
                        primary: true;
                        label: root.next-cta;
                        clicked => {
                            if root.stage == 1 {
                                root.import-evidence-clicked();
                            } else if root.stage == 3 {
                                root.navigate("Report");
                            } else {
                                root.navigate("Evidence");
                            }
                        }
                    }
                    LabButton {
                        primary: false;
                        label: Strings.import-evidence;
                        clicked => { root.import-evidence-clicked(); }
                    }
                    LabButton {
                        primary: false;
                        label: Strings.go-search;
                        clicked => { root.navigate("Search"); }
                    }
                    LabButton {
                        primary: false;
                        label: Strings.go-bookmarks;
                        clicked => { root.navigate("Bookmarks"); }
                    }
                }
                HorizontalLayout {
                    spacing: 12px;
                    Text {
                        text: Strings.status-evidence + ": \{root.evidence-count}";
                        color: Theme.text-secondary;
                        font-size: 11px;
                    }
                    Text {
                        text: Strings.status-coverage + ": \{root.coverage-count}";
                        color: Theme.text-secondary;
                        font-size: 11px;
                    }
                    Text {
                        text: Strings.status-bookmarks + ": \{root.bookmark-count}";
                        color: Theme.text-secondary;
                        font-size: 11px;
                    }
                }
            }
        }

        Text {
            text: Strings.activity;
            color: Theme.text-secondary;
            font-size: 11px;
            font-weight: 700;
        }

        if root.activity-lines.length == 0: Text {
            text: Strings.activity-empty;
            color: Theme.text-secondary;
            font-size: 12px;
        }

        if root.activity-lines.length > 0: Flickable {
            vertical-stretch: 1;
            viewport-width: parent.width - 16px;
            VerticalLayout {
                spacing: 4px;
                width: parent.width - 16px;
                for line in root.activity-lines: Text {
                    text: "·  " + line;
                    color: Theme.mono-fg;
                    font-family: "monospace";
                    font-size: 11px;
                    overflow: elide;
                }
            }
        }
    }
}
