import { Theme } from "../theme.slint";
import { Strings } from "../strings.slint";
import { EmptyState } from "../components/empty_state.slint";
import { PanelCard } from "../components/panel_card.slint";
import { ListRow } from "../components/list_row.slint";

export component ArtifactsScreen inherits Rectangle {
    in-out property <[string]> artifact-kinds: [];
    in-out property <[string]> artifact-summaries: [];
    in-out property <[string]> artifact-provenances: [];
    callback go-search-clicked();

    background: transparent;
    property <bool> has-hits: artifact-kinds.length > 0;

    if !has-hits: EmptyState {
        title: Strings.nav-artifacts;
        body: Strings.empty-hint-search;
        show-cta: true;
        cta-label: Strings.go-search;
        cta-clicked => { root.go-search-clicked(); }
    }

    if has-hits: VerticalLayout {
        padding: Theme.main-pad;
        spacing: 12px;
        Text {
            text: Strings.nav-artifacts + " · " + artifact-kinds.length + " " + Strings.hits;
            color: Theme.text-secondary;
            font-size: 11px;
            font-weight: 800;
            letter-spacing: 0.5px;
        }
        PanelCard {
            vertical-stretch: 1;
            VerticalLayout {
                padding: 12px;
                Flickable {
                    vertical-stretch: 1;
                    viewport-width: parent.width - 24px;
                    VerticalLayout {
                        spacing: 2px;
                        width: parent.width - 24px;
                        for i in artifact-kinds.length: ListRow {
                            leading: artifact-kinds[i];
                            primary: artifact-summaries[i];
                            trailing: artifact-provenances[i];
                        }
                    }
                }
            }
        }
    }
}
