import { Theme } from "../theme.slint";
import { Strings } from "../strings.slint";
import { EmptyState } from "../components/empty_state.slint";
import { PanelCard } from "../components/panel_card.slint";
import { ListRow } from "../components/list_row.slint";

export component GraphScreen inherits Rectangle {
    in-out property <[string]> graph-edges: [];
    callback go-evidence-clicked();

    background: transparent;
    property <bool> has-edges: graph-edges.length > 0;

    if !has-edges: EmptyState {
        title: Strings.nav-graph;
        body: Strings.empty-hint-graph;
        show-cta: true;
        cta-label: Strings.go-evidence;
        cta-clicked => { root.go-evidence-clicked(); }
    }

    if has-edges: VerticalLayout {
        padding: Theme.main-pad;
        spacing: 12px;
        Text {
            text: Strings.nav-graph + " · " + graph-edges.length + " " + Strings.edges-count;
            color: Theme.text-secondary;
            font-size: 11px;
            font-weight: 800;
            letter-spacing: 0.5px;
        }
        PanelCard {
            vertical-stretch: 1;
            VerticalLayout {
                padding: 12px;
                Flickable {
                    vertical-stretch: 1;
                    viewport-width: parent.width - 24px;
                    VerticalLayout {
                        spacing: 2px;
                        width: parent.width - 24px;
                        for edge in graph-edges: ListRow {
                            primary: edge;
                            mono-primary: true;
                        }
                    }
                }
            }
        }
    }
}
