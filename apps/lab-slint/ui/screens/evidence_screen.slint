import { Theme } from "../theme.slint";
import { Strings } from "../strings.slint";
import { SectionCard } from "../components/section_card.slint";
import { EmptyState } from "../components/empty_state.slint";
import { LabButton } from "../components/lab_button.slint";
import { StatusBadge } from "../components/status_badge.slint";

export component EvidenceRow inherits Rectangle {
    in-out property <string> name;
    in-out property <bool> deleted: false;
    in-out property <bool> selected: false;
    callback clicked();

    height: 30px;
    background: selected ? Theme.surface-raised : transparent;
    border-radius: 4px;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 8px;
        Text {
            text: root.name;
            color: Theme.text-primary;
            font-size: 12px;
            vertical-alignment: center;
            horizontal-stretch: 1;
            overflow: elide;
        }
        if root.deleted: StatusBadge {
            label: Strings.deleted;
            kind: "warn";
        }
    }

    ta := TouchArea {
        clicked => { root.clicked(); }
    }
    states [
        hover when ta.has-hover && !root.selected: { background: Theme.row-hover; }
    ]
}

export component EvidenceScreen inherits Rectangle {
    in-out property <[string]> evidence-names;
    in-out property <[string]> evidence-paths;
    in-out property <[string]> evidence-sizes;
    in-out property <[bool]> evidence-deleted;
    in-out property <int> selected-file-index: -1;
    callback import-evidence-clicked();
    callback evidence-row-selected(int);

    background: transparent;
    property <bool> body-wide: self.width >= 640px;
    property <bool> has-files: evidence-names.length > 0;
    property <bool> has-selection: selected-file-index >= 0 && selected-file-index < evidence-names.length;

    if !has-files: EmptyState {
        title: Strings.empty-no-evidence;
        body: Strings.empty-hint-evidence;
        show-cta: true;
        cta-label: Strings.import-evidence;
        cta-clicked => { root.import-evidence-clicked(); }
    }

    if has-files && body-wide: HorizontalLayout {
        padding: 12px;
        spacing: 12px;

        SectionCard {
            title: Strings.files-title;
            horizontal-stretch: 2;
            Flickable {
                vertical-stretch: 1;
                viewport-width: parent.width - 28px;
                VerticalLayout {
                    spacing: 2px;
                    width: parent.width - 28px;
                    for name[index] in root.evidence-names: EvidenceRow {
                        name: name;
                        deleted: index < root.evidence-deleted.length ? root.evidence-deleted[index] : false;
                        selected: root.selected-file-index == index;
                        clicked => { root.evidence-row-selected(index); }
                    }
                }
            }
        }

        SectionCard {
            title: Strings.detail-title;
            horizontal-stretch: 3;
            if !root.has-selection: Text {
                text: Strings.empty-no-selection;
                color: Theme.text-secondary;
                font-size: 12px;
            }
            if root.has-selection: VerticalLayout {
                spacing: 10px;
                Text {
                    text: Strings.col-name;
                    color: Theme.text-secondary;
                    font-size: 11px;
                }
                Text {
                    text: root.evidence-names[root.selected-file-index];
                    color: Theme.text-primary;
                    font-size: 13px;
                    font-weight: 600;
                }
                Text {
                    text: Strings.col-path;
                    color: Theme.text-secondary;
                    font-size: 11px;
                }
                Text {
                    text: root.selected-file-index < root.evidence-paths.length ? root.evidence-paths[root.selected-file-index] : "";
                    color: Theme.mono-fg;
                    font-family: "monospace";
                    font-size: 12px;
                    wrap: word-wrap;
                }
                Text {
                    text: Strings.col-size;
                    color: Theme.text-secondary;
                    font-size: 11px;
                }
                Text {
                    text: root.selected-file-index < root.evidence-sizes.length ? root.evidence-sizes[root.selected-file-index] : "";
                    color: Theme.mono-fg;
                    font-family: "monospace";
                    font-size: 12px;
                }
                if root.selected-file-index < root.evidence-deleted.length && root.evidence-deleted[root.selected-file-index]: StatusBadge {
                    label: Strings.deleted;
                    kind: "warn";
                }
            }
        }
    }

    if has-files && !body-wide: Flickable {
        VerticalLayout {
            padding: 12px;
            spacing: 12px;
            width: parent.width;
            SectionCard {
                title: Strings.files-title;
                VerticalLayout {
                    spacing: 2px;
                    for name[index] in root.evidence-names: EvidenceRow {
                        name: name;
                        deleted: index < root.evidence-deleted.length ? root.evidence-deleted[index] : false;
                        selected: root.selected-file-index == index;
                        clicked => { root.evidence-row-selected(index); }
                    }
                }
            }
            SectionCard {
                title: Strings.detail-title;
                if !root.has-selection: Text {
                    text: Strings.empty-no-selection;
                    color: Theme.text-secondary;
                    font-size: 12px;
                }
                if root.has-selection: VerticalLayout {
                    spacing: 8px;
                    Text {
                        text: root.evidence-names[root.selected-file-index];
                        color: Theme.text-primary;
                        font-size: 13px;
                        font-weight: 600;
                    }
                    Text {
                        text: root.selected-file-index < root.evidence-paths.length ? root.evidence-paths[root.selected-file-index] : "";
                        color: Theme.mono-fg;
                        font-family: "monospace";
                        font-size: 12px;
                        wrap: word-wrap;
                    }
                }
            }
        }
    }
}
