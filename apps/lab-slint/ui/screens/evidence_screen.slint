import { LineEdit } from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { Strings } from "../strings.slint";
import { EmptyState } from "../components/empty_state.slint";
import { StatusBadge } from "../components/status_badge.slint";

export component EvidenceRow inherits Rectangle {
    in-out property <string> name;
    in-out property <string> path;
    in-out property <string> size-label;
    in-out property <bool> deleted: false;
    in-out property <bool> selected: false;
    callback clicked();

    height: 26px;
    background: selected ? Theme.surface-raised : transparent;
    border-radius: 3px;

    HorizontalLayout {
        padding-left: 6px;
        padding-right: 6px;
        spacing: 8px;
        Text {
            text: root.name;
            color: Theme.text-primary;
            font-size: 12px;
            vertical-alignment: center;
            horizontal-stretch: 2;
            overflow: elide;
        }
        Text {
            text: root.path;
            color: Theme.mono-fg;
            font-family: "monospace";
            font-size: 11px;
            vertical-alignment: center;
            horizontal-stretch: 3;
            overflow: elide;
        }
        Text {
            text: root.size-label;
            color: Theme.mono-fg;
            font-family: "monospace";
            font-size: 11px;
            vertical-alignment: center;
            width: 72px;
            horizontal-alignment: right;
        }
        if root.deleted: StatusBadge {
            label: Strings.deleted;
            kind: "warn";
        }
    }

    ta := TouchArea {
        clicked => { root.clicked(); }
    }
    states [
        hover when ta.has-hover && !root.selected: { background: Theme.row-hover; }
    ]
}

/// Dense evidence table — detail lives in chrome Inspector.
export component EvidenceScreen inherits Rectangle {
    in-out property <[string]> evidence-names;
    in-out property <[string]> evidence-paths;
    in-out property <[string]> evidence-sizes;
    in-out property <[bool]> evidence-deleted;
    in-out property <int> selected-file-index: -1;
    in-out property <string> filter-text: "";
    callback import-evidence-clicked();
    callback evidence-row-selected(int);
    callback drop-import-clicked();

    background: transparent;
    property <bool> has-files: evidence-names.length > 0;

    if !has-files: VerticalLayout {
        padding: 8px;
        spacing: 8px;
        EmptyState {
            title: Strings.empty-no-evidence;
            body: Strings.empty-hint-evidence;
            show-cta: true;
            cta-label: Strings.import-evidence;
            cta-clicked => { root.import-evidence-clicked(); }
            vertical-stretch: 1;
        }
        Rectangle {
            height: 36px;
            border-width: 1px;
            border-color: Theme.border;
            border-radius: 4px;
            background: Theme.surface;
            HorizontalLayout {
                padding-left: 10px;
                padding-right: 10px;
                Text {
                    text: Strings.drop-import-hint;
                    color: Theme.text-secondary;
                    font-size: 11px;
                    vertical-alignment: center;
                    overflow: elide;
                }
            }
            TouchArea {
                clicked => { root.drop-import-clicked(); }
            }
        }
    }

    if has-files: VerticalLayout {
        padding: 8px;
        spacing: 6px;

        HorizontalLayout {
            spacing: 6px;
            LineEdit {
                text <=> root.filter-text;
                placeholder-text: Strings.filter-placeholder;
                horizontal-stretch: 1;
            }
            Text {
                text: Strings.shortcuts-hint;
                color: Theme.text-secondary;
                font-size: 11px;
                vertical-alignment: center;
            }
        }

        // Header
        Rectangle {
            height: 24px;
            background: Theme.surface;
            border-radius: 3px;
            HorizontalLayout {
                padding-left: 6px;
                padding-right: 6px;
                spacing: 8px;
                Text {
                    text: Strings.col-name;
                    color: Theme.text-secondary;
                    font-size: 11px;
                    font-weight: 700;
                    vertical-alignment: center;
                    horizontal-stretch: 2;
                }
                Text {
                    text: Strings.col-path;
                    color: Theme.text-secondary;
                    font-size: 11px;
                    font-weight: 700;
                    vertical-alignment: center;
                    horizontal-stretch: 3;
                }
                Text {
                    text: Strings.col-size;
                    color: Theme.text-secondary;
                    font-size: 11px;
                    font-weight: 700;
                    vertical-alignment: center;
                    width: 72px;
                    horizontal-alignment: right;
                }
            }
        }

        Flickable {
            vertical-stretch: 1;
            viewport-width: parent.width - 16px;
            VerticalLayout {
                spacing: 1px;
                width: parent.width - 16px;
                for name[index] in root.evidence-names: EvidenceRow {
                    name: name;
                    path: index < root.evidence-paths.length ? root.evidence-paths[index] : "";
                    size-label: index < root.evidence-sizes.length ? root.evidence-sizes[index] : "";
                    deleted: index < root.evidence-deleted.length ? root.evidence-deleted[index] : false;
                    selected: root.selected-file-index == index;
                    clicked => { root.evidence-row-selected(index); }
                }
            }
        }
    }
}
