import { LineEdit } from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { Strings } from "../strings.slint";
import { EmptyState } from "../components/empty_state.slint";
import { StatusBadge } from "../components/status_badge.slint";
import { LabButton } from "../components/lab_button.slint";
import { PanelCard } from "../components/panel_card.slint";

export component EvidenceRow inherits Rectangle {
    in-out property <string> name;
    in-out property <string> designation: "";
    in-out property <string> integrity: "";
    in-out property <bool> deleted: false;
    in-out property <bool> selected: false;
    callback clicked();

    height: 30px;
    background: selected ? Theme.accent-muted : transparent;
    border-radius: Theme.chip-radius;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        spacing: 8px;
        Text {
            text: root.name;
            color: Theme.text-primary;
            font-family: Theme.font-ui;
            font-size: 12px;
            font-weight: root.selected ? 700 : 500;
            vertical-alignment: center;
            horizontal-stretch: 1;
            overflow: elide;
        }
        if root.designation != "": Text {
            text: root.designation;
            color: Theme.text-secondary;
            font-size: 10px;
            vertical-alignment: center;
        }
        if root.integrity != "": StatusBadge {
            label: root.integrity;
            kind: root.integrity == "VerifiedMatch" ? "ok"
                : root.integrity == "VerifiedMismatch" ? "danger"
                : "info";
        }
        if root.deleted: StatusBadge {
            label: Strings.deleted;
            kind: "warn";
        }
    }

    ta := TouchArea {
        clicked => { root.clicked(); }
    }
    states [
        hover when ta.has-hover && !root.selected: { background: Theme.row-hover; }
    ]
}

/// FILES ~60% | DETAIL ~40% — Properties|Hex remain in chrome inspector drawer.
export component EvidenceScreen inherits Rectangle {
    in-out property <[string]> evidence-names;
    in-out property <[string]> evidence-paths: [];
    in-out property <[string]> evidence-sizes: [];
    in-out property <[string]> evidence-designations: [];
    in-out property <[string]> evidence-integrity: [];
    in-out property <[bool]> evidence-deleted;
    in-out property <int> selected-file-index: -1;
    in-out property <string> filter-text: "";
    in-out property <[string]> carve-hit-lines: [];
    callback import-evidence-clicked();
    callback evidence-row-selected(int);
    callback run-carving-clicked();
    callback bookmark-clicked();
    callback open-hex-clicked();

    background: transparent;
    property <bool> has-files: evidence-names.length > 0;
    property <bool> has-selection: selected-file-index >= 0 && selected-file-index < evidence-names.length;
    property <string> sel-name: root.has-selection ? root.evidence-names[root.selected-file-index] : "";
    property <string> sel-path: root.has-selection && root.selected-file-index < root.evidence-paths.length
        ? root.evidence-paths[root.selected-file-index] : "";
    property <string> sel-size: root.has-selection && root.selected-file-index < root.evidence-sizes.length
        ? root.evidence-sizes[root.selected-file-index] : "";
    property <string> sel-designation: root.has-selection && root.selected-file-index < root.evidence-designations.length
        ? root.evidence-designations[root.selected-file-index] : "";
    property <string> sel-integrity: root.has-selection && root.selected-file-index < root.evidence-integrity.length
        ? root.evidence-integrity[root.selected-file-index] : "";

    if !has-files: EmptyState {
        title: Strings.empty-no-evidence;
        body: Strings.empty-hint-evidence;
        show-cta: true;
        cta-label: Strings.import-evidence;
        cta-clicked => { root.import-evidence-clicked(); }
    }

    if has-files: HorizontalLayout {
        padding: 12px;
        spacing: 12px;

        PanelCard {
            horizontal-stretch: 1.5;
            VerticalLayout {
                padding: 14px;
                spacing: 10px;
                HorizontalLayout {
                    spacing: 8px;
                    LineEdit {
                        text <=> root.filter-text;
                        placeholder-text: Strings.filter-placeholder;
                        horizontal-stretch: 1;
                    }
                    LabButton {
                        primary: false;
                        label: Strings.import-evidence;
                        clicked => { root.import-evidence-clicked(); }
                    }
                    LabButton {
                        primary: true;
                        label: Strings.run-carving;
                        clicked => { root.run-carving-clicked(); }
                    }
                }
                Text {
                    text: Strings.files-title;
                    color: Theme.text-secondary;
                    font-size: 11px;
                    font-weight: 800;
                    letter-spacing: 0.5px;
                }
                Flickable {
                    vertical-stretch: 1;
                    viewport-width: parent.width - 28px;
                    VerticalLayout {
                        spacing: 2px;
                        width: parent.width - 28px;
                        for name[index] in root.evidence-names: EvidenceRow {
                            name: name;
                            designation: index < root.evidence-designations.length ? root.evidence-designations[index] : "";
                            integrity: index < root.evidence-integrity.length ? root.evidence-integrity[index] : "";
                            deleted: index < root.evidence-deleted.length ? root.evidence-deleted[index] : false;
                            selected: root.selected-file-index == index;
                            clicked => { root.evidence-row-selected(index); }
                        }
                    }
                }
                if root.carve-hit-lines.length > 0: VerticalLayout {
                    spacing: 4px;
                    Text {
                        text: Strings.carve-hits;
                        color: Theme.text-secondary;
                        font-size: 11px;
                        font-weight: 800;
                    }
                    for line in root.carve-hit-lines: Text {
                        text: line;
                        color: Theme.mono-fg;
                        font-family: "monospace";
                        font-size: 11px;
                        wrap: word-wrap;
                    }
                }
            }
        }

        PanelCard {
            horizontal-stretch: 1;
            VerticalLayout {
                padding: 14px;
                spacing: 10px;
                Text {
                    text: Strings.detail-title;
                    color: Theme.text-secondary;
                    font-size: 11px;
                    font-weight: 800;
                    letter-spacing: 0.5px;
                }
                if !root.has-selection: Text {
                    text: Strings.empty-no-selection;
                    color: Theme.text-secondary;
                    font-size: 12px;
                    wrap: word-wrap;
                }
                if root.has-selection: VerticalLayout {
                    spacing: 8px;
                    Text {
                        text: root.sel-name;
                        color: Theme.text-primary;
                        font-family: Theme.font-ui;
                        font-size: 15px;
                        font-weight: 800;
                        wrap: word-wrap;
                    }
                    if root.sel-path != "": Text {
                        text: root.sel-path;
                        color: Theme.mono-fg;
                        font-family: "monospace";
                        font-size: 11px;
                        wrap: word-wrap;
                    }
                    if root.sel-size != "": Text {
                        text: Strings.col-size + ": " + root.sel-size;
                        color: Theme.text-secondary;
                        font-size: 12px;
                    }
                    if root.sel-designation != "": Text {
                        text: Strings.designation + ": " + root.sel-designation;
                        color: Theme.text-secondary;
                        font-size: 12px;
                    }
                    if root.sel-integrity != "": StatusBadge {
                        label: root.sel-integrity;
                        kind: root.sel-integrity == "VerifiedMatch" ? "ok"
                            : root.sel-integrity == "VerifiedMismatch" ? "danger"
                            : "info";
                    }
                    LabButton {
                        primary: true;
                        label: Strings.add-bookmark;
                        clicked => { root.bookmark-clicked(); }
                    }
                    LabButton {
                        primary: false;
                        label: Strings.hex-title;
                        clicked => { root.open-hex-clicked(); }
                    }
                }
                Rectangle { vertical-stretch: 1; }
                Text {
                    text: Strings.shortcuts-hint;
                    color: Theme.text-secondary;
                    font-size: 10px;
                }
            }
        }
    }
}
