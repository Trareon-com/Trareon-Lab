import { Theme } from "../theme.slint";
import { Strings } from "../strings.slint";
import { PanelCard } from "../components/panel_card.slint";

export component AboutScreen inherits Rectangle {
    in-out property <string> about-line: "";
    in-out property <string> version-line: "";
    in-out property <string> disclosure-line: "";

    background: transparent;

    VerticalLayout {
        padding: Theme.main-pad;
        spacing: 12px;
        Text {
            text: Strings.nav-about;
            color: Theme.text-secondary;
            font-size: 11px;
            font-weight: 800;
            letter-spacing: 0.5px;
        }
        PanelCard {
            VerticalLayout {
                padding: 16px;
                spacing: 12px;
                Text {
                    text: root.version-line;
                    color: Theme.text-primary;
                    font-size: 16px;
                    font-weight: 800;
                }
                Rectangle {
                    background: Theme.warning-bg;
                    border-radius: Theme.chip-radius;
                    border-width: 1px;
                    border-color: Theme.accent;
                    VerticalLayout {
                        padding: 10px;
                        Text {
                            text: root.disclosure-line;
                            color: Theme.warning;
                            font-size: 12px;
                            font-weight: 700;
                            wrap: word-wrap;
                        }
                    }
                }
                Text {
                    text: root.about-line;
                    color: Theme.text-secondary;
                    font-size: 12px;
                    wrap: word-wrap;
                }
            }
        }
        Rectangle { vertical-stretch: 1; }
    }
}
