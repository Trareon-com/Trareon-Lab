import { Theme } from "../theme.slint";
import { Strings } from "../strings.slint";
import { SectionCard } from "../components/section_card.slint";

export component AboutScreen inherits Rectangle {
    in-out property <string> about-line: "";
    in-out property <string> version-line: "";
    in-out property <string> disclosure-line: "";

    background: transparent;

    VerticalLayout {
        padding: Theme.main-pad;
        spacing: 12px;
        Text {
            text: Strings.nav-about;
            color: Theme.text-primary;
            font-size: 14px;
            font-weight: 700;
        }
        SectionCard {
            show-title: false;
            VerticalLayout {
                spacing: 10px;
                Text {
                    text: root.version-line;
                    color: Theme.text-primary;
                    font-size: 13px;
                    font-weight: 600;
                }
                Text {
                    text: root.disclosure-line;
                    color: Theme.warning;
                    font-size: 12px;
                    font-weight: 600;
                    wrap: word-wrap;
                }
                Text {
                    text: root.about-line;
                    color: Theme.text-secondary;
                    font-size: 12px;
                    wrap: word-wrap;
                }
            }
        }
    }
}
