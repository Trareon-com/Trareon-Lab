import { Theme } from "../theme.slint";
import { Strings } from "../strings.slint";
import { PanelCard } from "../components/panel_card.slint";
import { LabButton } from "../components/lab_button.slint";

export component QuickVerifyScreen inherits Rectangle {
    in-out property <[string]> meta-lines: [];
    in-out property <[string]> carve-lines: [];
    in-out property <[string]> timeline-lines: [];
    callback pick-file-clicked();
    callback discard-clicked();

    background: transparent;

    VerticalLayout {
        padding: Theme.main-pad;
        spacing: 12px;

        PanelCard {
            VerticalLayout {
                padding: 14px;
                spacing: 10px;
                Text {
                    text: Strings.quick-verify-title;
                    color: Theme.text-primary;
                    font-size: 16px;
                    font-weight: 800;
                }
                Rectangle {
                    background: Theme.warning-bg;
                    border-radius: Theme.chip-radius;
                    border-width: 1px;
                    border-color: Theme.accent;
                    HorizontalLayout {
                        padding: 8px;
                        Text {
                            text: Strings.ephemeral-banner;
                            color: Theme.accent;
                            font-size: 12px;
                            font-weight: 700;
                        }
                    }
                }
                LabButton {
                    primary: true;
                    prominent: true;
                    label: Strings.quick-verify;
                    clicked => { root.pick-file-clicked(); }
                }
                if root.meta-lines.length > 0: LabButton {
                    primary: false;
                    label: Strings.discard-ephemeral;
                    clicked => { root.discard-clicked(); }
                }
            }
        }

        HorizontalLayout {
            spacing: 12px;
            vertical-stretch: 1;

            PanelCard {
                horizontal-stretch: 1;
                VerticalLayout {
                    padding: 14px;
                    spacing: 8px;
                    Text {
                        text: Strings.meta-title;
                        color: Theme.text-secondary;
                        font-size: 11px;
                        font-weight: 800;
                        letter-spacing: 0.5px;
                    }
                    if root.meta-lines.length == 0: Text {
                        text: Strings.empty-hint-evidence;
                        color: Theme.text-secondary;
                        font-size: 12px;
                        wrap: word-wrap;
                    }
                    for line in root.meta-lines: Text {
                        text: line;
                        color: Theme.mono-fg;
                        font-family: "monospace";
                        font-size: 11px;
                        wrap: word-wrap;
                    }
                }
            }

            PanelCard {
                horizontal-stretch: 1;
                VerticalLayout {
                    padding: 14px;
                    spacing: 8px;
                    Text {
                        text: Strings.carve-hits;
                        color: Theme.text-secondary;
                        font-size: 11px;
                        font-weight: 800;
                        letter-spacing: 0.5px;
                    }
                    if root.carve-lines.length == 0: Text {
                        text: Strings.carve-empty;
                        color: Theme.text-secondary;
                        font-size: 12px;
                    }
                    for line in root.carve-lines: Text {
                        text: line;
                        color: Theme.text-primary;
                        font-size: 11px;
                        font-family: "monospace";
                        wrap: word-wrap;
                    }
                }
            }
        }

        PanelCard {
            VerticalLayout {
                padding: 14px;
                spacing: 8px;
                Text {
                    text: Strings.host-timeline-title;
                    color: Theme.text-secondary;
                    font-size: 11px;
                    font-weight: 800;
                    letter-spacing: 0.5px;
                }
                if root.timeline-lines.length == 0: Text {
                    text: Strings.empty-no-timeline;
                    color: Theme.text-secondary;
                    font-size: 12px;
                }
                for line in root.timeline-lines: Text {
                    text: line;
                    color: Theme.mono-fg;
                    font-family: "monospace";
                    font-size: 11px;
                }
            }
        }
    }
}
