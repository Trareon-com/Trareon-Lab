import { Theme } from "../theme.slint";
import { Strings } from "../strings.slint";
import { PanelCard } from "../components/panel_card.slint";
import { EmptyState } from "../components/empty_state.slint";
import { ListRow } from "../components/list_row.slint";

export component RunsScreen inherits Rectangle {
    in-out property <[string]> run-lines: [];
    background: transparent;
    property <bool> has-runs: run-lines.length > 0;

    if !has-runs: EmptyState {
        title: Strings.runs-title;
        body: Strings.runs-empty;
        show-cta: false;
    }
    if has-runs: VerticalLayout {
        padding: Theme.main-pad;
        spacing: 12px;
        Text {
            text: Strings.runs-title;
            color: Theme.text-secondary;
            font-size: 11px;
            font-weight: 800;
            letter-spacing: 0.5px;
        }
        PanelCard {
            vertical-stretch: 1;
            VerticalLayout {
                padding: 12px;
                Flickable {
                    vertical-stretch: 1;
                    viewport-width: parent.width - 24px;
                    VerticalLayout {
                        spacing: 2px;
                        width: parent.width - 24px;
                        for line in root.run-lines: ListRow {
                            primary: line;
                            mono-primary: true;
                            row-height: 36px;
                        }
                    }
                }
            }
        }
    }
}
