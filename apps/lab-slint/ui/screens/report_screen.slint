import { Theme } from "../theme.slint";
import { Strings } from "../strings.slint";
import { EmptyState } from "../components/empty_state.slint";
import { StatusBadge } from "../components/status_badge.slint";
import { LabButton } from "../components/lab_button.slint";
import { PanelCard } from "../components/panel_card.slint";

export component ReportScreen inherits Rectangle {
    in-out property <string> report-state;
    in-out property <[string]> finding-claims;
    in-out property <[string]> finding-uuids;
    in-out property <string> about-line;
    in-out property <bool> report-finalizable: false;
    in-out property <[string]> report-blockers: [];
    in-out property <string> export-status: "";
    in-out property <[string]> export-format-labels: [];
    in-out property <int> selected-export-format: 0;
    callback export-clicked();
    callback transfer-export-clicked();
    callback export-format-selected(int);

    background: transparent;
    property <bool> empty: finding-claims.length == 0;

    HorizontalLayout {
        padding: 12px;
        spacing: 12px;

        PanelCard {
            horizontal-stretch: 1;
            VerticalLayout {
                padding: 14px;
                spacing: 12px;
                Text {
                    text: Strings.report-state;
                    color: Theme.text-secondary;
                    font-size: 11px;
                    font-weight: 800;
                    letter-spacing: 0.5px;
                }
                HorizontalLayout {
                    spacing: 8px;
                    StatusBadge {
                        label: root.report-state;
                        kind: root.report-state == "draft" ? "warn" : "ok";
                    }
                    StatusBadge {
                        label: root.report-finalizable ? "finalizable" : "blocked";
                        kind: root.report-finalizable ? "ok" : "danger";
                    }
                }
                Text {
                    text: Strings.sod-hint;
                    color: Theme.text-secondary;
                    font-size: 11px;
                    wrap: word-wrap;
                }
                if root.report-blockers.length > 0: VerticalLayout {
                    spacing: 4px;
                    Text {
                        text: Strings.report-blockers-title;
                        color: Theme.danger;
                        font-size: 11px;
                        font-weight: 800;
                    }
                    for b in root.report-blockers: Text {
                        text: "·  " + b;
                        color: Theme.danger;
                        font-size: 12px;
                        wrap: word-wrap;
                    }
                }
                if root.export-format-labels.length > 0: VerticalLayout {
                    spacing: 6px;
                    Text {
                        text: Strings.export-format;
                        color: Theme.text-secondary;
                        font-size: 11px;
                        font-weight: 800;
                        letter-spacing: 0.5px;
                    }
                    for fmt[index] in root.export-format-labels: Rectangle {
                        height: 28px;
                        border-radius: Theme.chip-radius;
                        border-width: 1px;
                        border-color: root.selected-export-format == index ? Theme.accent : Theme.border;
                        background: root.selected-export-format == index ? Theme.accent-muted : Theme.surface;
                        HorizontalLayout {
                            padding-left: 10px;
                            padding-right: 10px;
                            Text {
                                text: fmt;
                                color: Theme.text-primary;
                                font-size: 12px;
                                font-weight: root.selected-export-format == index ? 700 : 500;
                                vertical-alignment: center;
                            }
                        }
                        TouchArea {
                            clicked => {
                                root.selected-export-format = index;
                                root.export-format-selected(index);
                            }
                        }
                    }
                }
                if root.export-status != "": Text {
                    text: root.export-status;
                    color: Theme.mono-fg;
                    font-family: "monospace";
                    font-size: 11px;
                    wrap: word-wrap;
                }
                LabButton {
                    primary: true;
                    prominent: true;
                    enabled: root.report-finalizable;
                    label: Strings.export-action;
                    clicked => { root.export-clicked(); }
                }
                LabButton {
                    primary: false;
                    label: Strings.transfer-export;
                    clicked => { root.transfer-export-clicked(); }
                }
                Rectangle { vertical-stretch: 1; }
                Text {
                    text: root.about-line;
                    color: Theme.text-secondary;
                    font-size: 10px;
                    wrap: word-wrap;
                }
            }
        }

        PanelCard {
            horizontal-stretch: 1.4;
            VerticalLayout {
                padding: 14px;
                spacing: 10px;
                Text {
                    text: Strings.col-claim;
                    color: Theme.text-secondary;
                    font-size: 11px;
                    font-weight: 800;
                    letter-spacing: 0.5px;
                }
                if empty: EmptyState {
                    title: Strings.empty-no-findings;
                    body: Strings.empty-hint-report;
                    vertical-stretch: 1;
                }
                if !empty: Flickable {
                    vertical-stretch: 1;
                    viewport-width: parent.width - 28px;
                    VerticalLayout {
                        spacing: 6px;
                        width: parent.width - 28px;
                        for claim[index] in root.finding-claims: Rectangle {
                            border-width: 1px;
                            border-color: Theme.border;
                            border-radius: Theme.chip-radius;
                            background: Theme.surface;
                            VerticalLayout {
                                padding: 10px;
                                spacing: 4px;
                                Text {
                                    text: claim;
                                    color: Theme.text-primary;
                                    font-size: 12px;
                                    wrap: word-wrap;
                                }
                                Text {
                                    text: index < root.finding-uuids.length ? root.finding-uuids[index] : "";
                                    color: Theme.mono-fg;
                                    font-family: "monospace";
                                    font-size: 11px;
                                    overflow: elide;
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
