import { LineEdit } from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { Strings } from "../strings.slint";
import { SectionCard } from "../components/section_card.slint";
import { EmptyState } from "../components/empty_state.slint";
import { LabButton } from "../components/lab_button.slint";

export component TimelineScreen inherits Rectangle {
    in-out property <[string]> timeline-labels;
    callback jump-evidence-clicked();
    callback bookmark-hit-clicked();
    callback import-timeline-clicked();

    background: transparent;
    property <bool> empty: timeline-labels.length == 0;
    property <int> event-count: timeline-labels.length;

    VerticalLayout {
        padding: 12px;
        spacing: 12px;

        HorizontalLayout {
            spacing: 8px;
            LineEdit {
                placeholder-text: Strings.filter-stub;
                enabled: false;
                horizontal-stretch: 1;
            }
            LabButton {
                primary: false;
                label: Strings.import-timeline;
                clicked => { root.import-timeline-clicked(); }
            }
            if !empty: LabButton {
                primary: false;
                label: Strings.jump-evidence;
                clicked => { root.jump-evidence-clicked(); }
            }
            if !empty: LabButton {
                primary: false;
                label: Strings.add-bookmark;
                clicked => { root.bookmark-hit-clicked(); }
            }
        }

        if !empty: Rectangle {
            height: 36px;
            border-radius: 4px;
            background: Theme.surface-raised;
            border-width: 1px;
            border-color: Theme.border;
            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 4px;
                Text {
                    text: "\{root.event-count}";
                    color: Theme.text-secondary;
                    font-size: 11px;
                    vertical-alignment: center;
                }
                Rectangle {
                    horizontal-stretch: 1;
                    height: 12px;
                    background: Theme.accent-muted;
                    border-radius: 2px;
                }
                Text {
                    text: "CFTL-lite overview";
                    color: Theme.text-secondary;
                    font-size: 10px;
                    vertical-alignment: center;
                }
            }
        }

        if empty: EmptyState {
            title: Strings.empty-no-timeline;
            body: Strings.empty-hint-timeline;
            vertical-stretch: 1;
        }

        if !empty: SectionCard {
            title: Strings.col-event;
            vertical-stretch: 1;
            Flickable {
                vertical-stretch: 1;
                viewport-width: parent.width - 28px;
                VerticalLayout {
                    spacing: 2px;
                    width: parent.width - 28px;
                    for label in root.timeline-labels: Rectangle {
                        height: 28px;
                        border-radius: 4px;
                        background: transparent;
                        HorizontalLayout {
                            padding-left: 8px;
                            padding-right: 8px;
                            Text {
                                text: label;
                                color: Theme.mono-fg;
                                font-family: "monospace";
                                font-size: 12px;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                        }
                    }
                }
            }
        }
    }
}
