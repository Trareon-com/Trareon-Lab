import { Theme } from "../theme.slint";
import { Strings } from "../strings.slint";
import { LabButton } from "../components/lab_button.slint";
import { EmptyState } from "../components/empty_state.slint";
import { PanelCard } from "../components/panel_card.slint";

/// Full-width hex pop-out — same pipeline as Inspector Hex tab.
export component HexScreen inherits Rectangle {
    in-out property <string> hex-status: "";
    in-out property <[string]> hex-lines: [];
    in-out property <bool> has-selection: false;
    callback prev-clicked();
    callback next-clicked();
    callback open-evidence-clicked();

    background: transparent;

    if !root.has-selection: EmptyState {
        title: Strings.hex-title;
        body: Strings.hex-empty-body;
        show-cta: true;
        cta-label: Strings.go-evidence;
        cta-clicked => { root.open-evidence-clicked(); }
    }

    if root.has-selection: VerticalLayout {
        padding: Theme.main-pad;
        spacing: 10px;
        HorizontalLayout {
            spacing: 8px;
            Text {
                text: Strings.hex-title;
                color: Theme.text-secondary;
                font-size: 11px;
                font-weight: 800;
                letter-spacing: 0.5px;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }
            LabButton { primary: false; label: Strings.hex-prev; clicked => { root.prev-clicked(); } }
            LabButton { primary: false; label: Strings.hex-next; clicked => { root.next-clicked(); } }
        }
        Text {
            text: root.hex-status;
            color: Theme.text-secondary;
            font-size: 12px;
            wrap: word-wrap;
        }
        PanelCard {
            vertical-stretch: 1;
            VerticalLayout {
                padding: 12px;
                Flickable {
                    vertical-stretch: 1;
                    viewport-width: parent.width - 24px;
                    VerticalLayout {
                        spacing: 1px;
                        width: parent.width - 24px;
                        for line in root.hex-lines: Text {
                            text: line;
                            color: Theme.mono-fg;
                            font-family: "monospace";
                            font-size: 11px;
                        }
                    }
                }
            }
        }
    }
}
