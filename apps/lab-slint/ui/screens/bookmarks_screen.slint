import { Theme } from "../theme.slint";
import { Strings } from "../strings.slint";
import { EmptyState } from "../components/empty_state.slint";
import { LabButton } from "../components/lab_button.slint";
import { PanelCard } from "../components/panel_card.slint";

export component BookmarksScreen inherits Rectangle {
    in-out property <[string]> finding-claims;
    in-out property <[string]> finding-uuids;
    in-out property <int> bookmark-count;
    callback navigate-report();
    callback go-evidence-clicked();

    background: transparent;
    property <bool> empty: finding-claims.length == 0 && bookmark-count == 0;
    property <int> selected-index: -1;
    property <string> selected-claim: root.selected-index >= 0 && root.selected-index < root.finding-claims.length
        ? root.finding-claims[root.selected-index] : "";
    property <string> selected-uuid: root.selected-index >= 0 && root.selected-index < root.finding-uuids.length
        ? root.finding-uuids[root.selected-index] : "";

    if empty: VerticalLayout {
        padding: 12px;
        EmptyState {
            title: Strings.empty-no-bookmarks;
            body: Strings.empty-hint-bookmarks;
            show-cta: true;
            cta-label: Strings.go-evidence;
            cta-clicked => { root.go-evidence-clicked(); }
            vertical-stretch: 1;
        }
    }

    if !empty: HorizontalLayout {
        padding: 12px;
        spacing: 12px;

        PanelCard {
            horizontal-stretch: 1.3;
            VerticalLayout {
                padding: 14px;
                spacing: 10px;
                Text {
                    text: Strings.status-bookmarks + " · " + root.bookmark-count;
                    color: Theme.text-secondary;
                    font-size: 11px;
                    font-weight: 800;
                    letter-spacing: 0.5px;
                }
                Flickable {
                    vertical-stretch: 1;
                    viewport-width: parent.width - 28px;
                    VerticalLayout {
                        spacing: 6px;
                        width: parent.width - 28px;
                        for claim[index] in root.finding-claims: Rectangle {
                            border-width: 1px;
                            border-color: root.selected-index == index ? Theme.accent : Theme.border;
                            border-radius: Theme.chip-radius;
                            background: root.selected-index == index ? Theme.accent-muted : Theme.surface;
                            VerticalLayout {
                                padding: 10px;
                                spacing: 4px;
                                Text {
                                    text: claim;
                                    color: Theme.text-primary;
                                    font-size: 12px;
                                    wrap: word-wrap;
                                }
                                Text {
                                    text: index < root.finding-uuids.length ? root.finding-uuids[index] : "";
                                    color: Theme.mono-fg;
                                    font-family: "monospace";
                                    font-size: 11px;
                                    overflow: elide;
                                }
                            }
                            TouchArea {
                                clicked => { root.selected-index = index; }
                            }
                        }
                    }
                }
            }
        }

        PanelCard {
            horizontal-stretch: 1;
            VerticalLayout {
                padding: 14px;
                spacing: 10px;
                Text {
                    text: Strings.queue-for-report;
                    color: Theme.text-secondary;
                    font-size: 11px;
                    font-weight: 800;
                    letter-spacing: 0.5px;
                }
                if root.selected-claim == "": Text {
                    text: Strings.claim-select-hint;
                    color: Theme.text-secondary;
                    font-size: 12px;
                    wrap: word-wrap;
                }
                if root.selected-claim != "": Text {
                    text: Strings.work-product-hint;
                    color: Theme.text-secondary;
                    font-size: 12px;
                    wrap: word-wrap;
                }
                if root.selected-claim != "": Text {
                    text: root.selected-claim;
                    color: Theme.text-primary;
                    font-size: 13px;
                    font-weight: 700;
                    wrap: word-wrap;
                }
                if root.selected-uuid != "": Text {
                    text: root.selected-uuid;
                    color: Theme.mono-fg;
                    font-family: "monospace";
                    font-size: 11px;
                    wrap: word-wrap;
                }
                LabButton {
                    primary: true;
                    prominent: true;
                    enabled: root.selected-claim != "";
                    label: Strings.go-report;
                    clicked => { root.navigate-report(); }
                }
                Rectangle { vertical-stretch: 1; }
            }
        }
    }
}
