import { Theme } from "../theme.slint";

export component LabButton inherits Rectangle {
    in-out property <string> label;
    in-out property <bool> primary: false;
    in-out property <bool> enabled: true;
    callback clicked();

    height: 34px;
    min-width: 108px;
    horizontal-stretch: 0;
    vertical-stretch: 0;
    border-radius: 5px;
    border-width: primary ? 0px : 1px;
    border-color: Theme.border;
    background: !enabled ? Theme.surface-raised
        : primary ? Theme.accent
        : Theme.surface-raised;
    opacity: enabled ? 1.0 : 0.5;

    HorizontalLayout {
        padding-left: 16px;
        padding-right: 16px;
        alignment: center;
        Text {
            text: root.label;
            color: root.primary && root.enabled ? Theme.on-accent : Theme.text-primary;
            font-size: 12px;
            font-weight: 600;
            vertical-alignment: center;
            horizontal-alignment: center;
        }
    }

    ta := TouchArea {
        enabled: root.enabled;
        clicked => {
            root.clicked();
        }
    }

    states [
        hover when ta.has-hover && root.enabled && !root.primary: {
            background: Theme.row-hover;
            border-color: Theme.accent-muted;
        }
        hover-primary when ta.has-hover && root.enabled && root.primary: {
            background: Theme.accent-muted;
        }
    ]
}
