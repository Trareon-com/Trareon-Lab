import { Theme } from "../theme.slint";

export component NavItem inherits Rectangle {
    in-out property <string> label;
    in-out property <string> glyph: "•";
    in-out property <bool> active: false;
    callback clicked();

    height: 32px;
    background: active ? Theme.accent-muted : transparent;
    border-radius: 6px;

    if root.active: Rectangle {
        x: 0px;
        y: 0px;
        width: 3px;
        height: parent.height;
        background: Theme.nav-active-bar;
    }

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 8px;
        spacing: 10px;

        Text {
            text: root.glyph;
            color: root.active ? Theme.accent : Theme.text-secondary;
            vertical-alignment: center;
            font-size: 13px;
            font-weight: root.active ? 700 : 400;
        }

        Text {
            text: root.label;
            color: root.active ? Theme.accent : Theme.text-secondary;
            font-size: 12px;
            font-weight: root.active ? 700 : 500;
            vertical-alignment: center;
            horizontal-stretch: 1;
            overflow: elide;
        }
    }

    ta := TouchArea {
        clicked => {
            root.clicked();
        }
    }

    states [
        hover when ta.has-hover && !root.active: {
            background: Theme.row-hover;
        }
    ]
}
