import { Theme } from "../theme.slint";

/// Sticky honesty strip — unsigned well (Acquire ASCII).
export component DisclosureBanner inherits Rectangle {
    in-out property <string> line: "UNSIGNED — Lab use only · NOT court-ready · NOT ISO-certified";

    height: Theme.disclosure-height;
    background: Theme.warning-bg;

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 8px;
        Text {
            text: "⚠";
            color: Theme.tile-warn-fg;
            font-size: 11px;
            font-weight: 800;
            vertical-alignment: center;
        }
        Text {
            text: root.line;
            color: Theme.tile-warn-fg;
            font-family: Theme.font-ui;
            font-size: 11px;
            font-weight: 700;
            vertical-alignment: center;
            horizontal-stretch: 1;
            overflow: elide;
        }
    }
}
