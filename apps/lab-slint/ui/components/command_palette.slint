import { LineEdit } from "std-widgets.slint";
import { Theme } from "../theme.slint";
import { Strings } from "../strings.slint";
import { ListRow } from "list_row.slint";

/// Raycast-style command palette overlay.
export component CommandPalette inherits Rectangle {
    in-out property <string> filter: "";
    in-out property <[string]> commands: [];
    in-out property <int> selected-index: 0;
    callback filter-changed(string);
    callback command-activated(string);
    callback dismissed();

    background: #00000088;

    TouchArea {
        clicked => { root.dismissed(); }
    }

    plate := Rectangle {
        x: (parent.width - self.width) / 2;
        y: parent.height * 0.18;
        width: min(520px, parent.width - 48px);
        height: min(360px, parent.height * 0.55);
        background: Theme.surface;
        border-width: 1px;
        border-color: Theme.border;
        border-radius: Theme.panel-radius;
        drop-shadow-blur: 16px;
        drop-shadow-color: Theme.shadow;
        drop-shadow-offset-y: 4px;
        clip: true;

        VerticalLayout {
            padding: 12px;
            spacing: 8px;

            Text {
                text: Strings.command-palette;
                color: Theme.text-secondary;
                font-size: 11px;
                font-weight: 800;
                letter-spacing: 0.5px;
            }

            LineEdit {
                text <=> root.filter;
                placeholder-text: Strings.command-placeholder;
                edited => { root.filter-changed(self.text); }
                accepted => {
                    if root.commands.length > 0 {
                        root.command-activated(root.commands[root.selected-index]);
                    }
                }
            }

            if root.commands.length == 0: Text {
                text: Strings.command-hint;
                color: Theme.icon-muted;
                font-size: 12px;
                horizontal-stretch: 1;
                vertical-stretch: 1;
                vertical-alignment: center;
                horizontal-alignment: center;
            }

            if root.commands.length > 0: Flickable {
                vertical-stretch: 1;
                viewport-width: parent.width - 24px;
                VerticalLayout {
                    spacing: 2px;
                    width: parent.width - 24px;
                    for cmd[index] in root.commands: ListRow {
                        primary: cmd;
                        selected: index == root.selected-index;
                        clicked => { root.command-activated(cmd); }
                    }
                }
            }

            Text {
                text: Strings.command-hint;
                color: Theme.text-secondary;
                font-size: 11px;
            }
        }
    }
}
