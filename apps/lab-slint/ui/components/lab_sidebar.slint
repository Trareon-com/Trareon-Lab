import { Theme } from "../theme.slint";
import { Strings } from "../strings.slint";
import { Icon } from "icon.slint";

component RailItem inherits Rectangle {
    in-out property <image> glyph;
    in-out property <string> label;
    in-out property <bool> active: false;
    in-out property <bool> show-label: true;
    callback clicked();

    height: Theme.nav-row-height;
    background: root.active ? Theme.accent-muted : transparent;
    border-radius: Theme.chip-radius;

    if root.show-label: HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;
        spacing: 10px;
        Rectangle {
            width: 3px;
            background: root.active ? Theme.nav-active-bar : transparent;
            border-radius: 1.5px;
        }
        Icon {
            glyph: root.glyph;
            size: 16px;
            tint: root.active ? Theme.icon-active : Theme.icon-muted;
            vertical-alignment: center;
        }
        Text {
            text: root.label;
            color: root.active ? Theme.accent : Theme.text-primary;
            font-family: Theme.font-ui;
            font-size: 12px;
            font-weight: root.active ? 700 : 500;
            vertical-alignment: center;
            horizontal-stretch: 1;
            overflow: elide;
        }
    }
    if !root.show-label: HorizontalLayout {
        alignment: center;
        Icon {
            glyph: root.glyph;
            size: 18px;
            tint: root.active ? Theme.icon-active : Theme.icon-muted;
            vertical-alignment: center;
            horizontal-alignment: center;
        }
    }

    ta := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
    // Tooltip well when compact (icon rail)
    if !root.show-label && ta.has-hover: Rectangle {
        x: parent.width + 6px;
        y: (parent.height - 22px) / 2;
        height: 22px;
        background: Theme.surface;
        border-width: 1px;
        border-color: Theme.border;
        border-radius: Theme.chip-radius;
        drop-shadow-blur: 8px;
        drop-shadow-color: Theme.shadow;
        HorizontalLayout {
            padding-left: 8px;
            padding-right: 8px;
            Text {
                text: root.label;
                color: Theme.text-primary;
                font-size: 11px;
                font-weight: 600;
                vertical-alignment: center;
            }
        }
    }
    states [ hover when ta.has-hover && !root.active: { background: Theme.row-hover; } ]
}

component GroupLabel inherits Rectangle {
    in-out property <string> label;
    in-out property <bool> show-label: true;
    height: root.show-label ? 22px : 8px;
    if root.show-label: HorizontalLayout {
        padding-left: 14px;
        padding-top: 6px;
        Text {
            text: root.label;
            color: Theme.text-secondary;
            font-family: Theme.font-ui;
            font-size: 9px;
            font-weight: 700;
            letter-spacing: 0.6px;
        }
    }
}

component ToolRow inherits Rectangle {
    in-out property <string> label;
    in-out property <bool> active: false;
    in-out property <bool> show-label: true;
    callback clicked();
    height: root.show-label ? 28px : 0px;
    visible: root.show-label;
    background: root.active ? Theme.accent-muted : transparent;
    border-radius: Theme.chip-radius;
    HorizontalLayout {
        padding-left: 28px;
        padding-right: 10px;
        Text {
            text: root.label;
            color: root.active ? Theme.accent : Theme.text-secondary;
            font-family: Theme.font-ui;
            font-size: 11px;
            font-weight: root.active ? 700 : 500;
            vertical-alignment: center;
            overflow: elide;
        }
    }
    ta := TouchArea { clicked => { root.clicked(); } }
    states [ hover when ta.has-hover: { background: Theme.row-hover; } ]
}

/// ASCII rail: WORKFLOW · LAB · SUPPORT — 188 ↔ 56.
export component LabSidebar inherits Rectangle {
    in-out property <string> active-key: "Case";
    in-out property <bool> expanded: true;
    in-out property <string> version-line: "";
    callback navigate-key(string);

    width: root.expanded ? Theme.sidebar-width : Theme.sidebar-rail-width;
    background: Theme.sidebar-bg;

    HorizontalLayout {
        spacing: 0px;
        VerticalLayout {
            padding-top: 10px;
            padding-bottom: 8px;
            padding-left: 6px;
            padding-right: 6px;
            spacing: 1px;

            if root.expanded: VerticalLayout {
                padding-left: 8px;
                padding-right: 8px;
                padding-bottom: 10px;
                spacing: 2px;
                HorizontalLayout {
                    spacing: 8px;
                    Rectangle {
                        width: 26px;
                        height: 26px;
                        border-radius: 6px;
                        background: Theme.accent;
                        Text {
                            text: "T";
                            color: Theme.on-accent;
                            font-size: 13px;
                            font-weight: 800;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                    VerticalLayout {
                        spacing: 0px;
                        Text {
                            text: "TRAREON LAB";
                            color: Theme.text-primary;
                            font-family: Theme.font-ui;
                            font-size: 11px;
                            font-weight: 800;
                            letter-spacing: 0.3px;
                        }
                        Text {
                            text: Strings.brand-subtitle;
                            color: Theme.icon-muted;
                            font-family: Theme.font-ui;
                            font-size: 8px;
                            font-weight: 700;
                            letter-spacing: 0.4px;
                            overflow: elide;
                        }
                    }
                }
                Rectangle { height: 8px; }
                Rectangle { height: 1px; background: Theme.border; }
            }

            GroupLabel { label: Strings.nav-group-workflow; show-label: root.expanded; }
            RailItem {
                glyph: @image-url("../assets/icons/nav-cases.png");
                label: Strings.nav-case;
                show-label: root.expanded;
                active: root.active-key == "Case" || root.active-key == "Home";
                clicked => { root.navigate-key("Case"); }
            }
            RailItem {
                glyph: @image-url("../assets/icons/nav-lab.png");
                label: Strings.nav-evidence;
                show-label: root.expanded;
                active: root.active-key == "Evidence";
                clicked => { root.navigate-key("Evidence"); }
            }
            RailItem {
                glyph: @image-url("../assets/icons/nav-search.png");
                label: Strings.nav-search;
                show-label: root.expanded;
                active: root.active-key == "Search";
                clicked => { root.navigate-key("Search"); }
            }
            RailItem {
                glyph: @image-url("../assets/icons/nav-timeline.png");
                label: Strings.nav-timeline;
                show-label: root.expanded;
                active: root.active-key == "Timeline";
                clicked => { root.navigate-key("Timeline"); }
            }
            RailItem {
                glyph: @image-url("../assets/icons/nav-bookmark.png");
                label: Strings.nav-bookmarks;
                show-label: root.expanded;
                active: root.active-key == "Bookmarks";
                clicked => { root.navigate-key("Bookmarks"); }
            }
            RailItem {
                glyph: @image-url("../assets/icons/nav-report.png");
                label: Strings.nav-report;
                show-label: root.expanded;
                active: root.active-key == "Report";
                clicked => { root.navigate-key("Report"); }
            }

            GroupLabel { label: Strings.nav-group-lab; show-label: root.expanded; }
            ToolRow {
                label: Strings.nav-artifacts;
                show-label: root.expanded;
                active: root.active-key == "Artifacts";
                clicked => { root.navigate-key("Artifacts"); }
            }
            ToolRow {
                label: Strings.nav-graph;
                show-label: root.expanded;
                active: root.active-key == "Graph";
                clicked => { root.navigate-key("Graph"); }
            }
            ToolRow {
                label: Strings.nav-runs;
                show-label: root.expanded;
                active: root.active-key == "Runs";
                clicked => { root.navigate-key("Runs"); }
            }
            ToolRow {
                label: Strings.nav-transfer;
                show-label: root.expanded;
                active: root.active-key == "Transfer";
                clicked => { root.navigate-key("Transfer"); }
            }
            ToolRow {
                label: Strings.quick-verify;
                show-label: root.expanded;
                active: root.active-key == "QuickVerify";
                clicked => { root.navigate-key("QuickVerify"); }
            }

            GroupLabel { label: Strings.nav-group-support; show-label: root.expanded; }
            ToolRow {
                label: Strings.nav-capabilities;
                show-label: root.expanded;
                active: root.active-key == "Capabilities";
                clicked => { root.navigate-key("Capabilities"); }
            }
            ToolRow {
                label: Strings.nav-about;
                show-label: root.expanded;
                active: root.active-key == "About";
                clicked => { root.navigate-key("About"); }
            }

            Rectangle { vertical-stretch: 1; }

            if root.expanded: VerticalLayout {
                padding-left: 10px;
                padding-right: 8px;
                padding-top: 8px;
                spacing: 4px;
                Rectangle { height: 1px; background: Theme.border; }
                HorizontalLayout {
                    spacing: 6px;
                    Text {
                        text: "●";
                        color: Theme.success;
                        font-size: 9px;
                        vertical-alignment: center;
                    }
                    Text {
                        text: Strings.system-healthy;
                        color: Theme.success;
                        font-family: Theme.font-ui;
                        font-size: 10px;
                        font-weight: 700;
                        vertical-alignment: center;
                    }
                }
                if root.version-line != "": Text {
                    text: root.version-line;
                    color: Theme.icon-muted;
                    font-family: Theme.font-ui;
                    font-size: 9px;
                    overflow: elide;
                }
            }
        }
        Rectangle { width: 1px; background: Theme.border; }
    }
}
