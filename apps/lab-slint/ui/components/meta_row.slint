import { Theme } from "../theme.slint";

/// Small-caps label + bold value (Acquire device-details pattern).
export component MetaRow inherits HorizontalLayout {
    in-out property <string> label;
    in-out property <string> value;
    spacing: 12px;
    padding-top: 2px;
    padding-bottom: 2px;

    Text {
        width: 110px;
        text: root.label;
        color: Theme.text-secondary;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.5px;
        vertical-alignment: center;
    }
    Text {
        text: root.value;
        color: Theme.text-primary;
        font-size: 12px;
        font-weight: 700;
        vertical-alignment: center;
        horizontal-stretch: 1;
        overflow: elide;
        wrap: word-wrap;
    }
}
