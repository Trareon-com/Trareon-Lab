import { Theme } from "../theme.slint";

export component MetricTile inherits Rectangle {
    in-out property <string> label;
    in-out property <int> value;

    background: Theme.surface-raised;
    border-width: 1px;
    border-color: Theme.border;
    border-radius: 5px;
    min-height: 64px;
    horizontal-stretch: 1;

    VerticalLayout {
        padding: 12px;
        spacing: 6px;

        Text {
            text: root.label;
            color: Theme.text-secondary;
            font-size: 11px;
            font-weight: 600;
        }

        Text {
            text: "\{root.value}";
            color: root.value == 0 ? Theme.text-secondary : Theme.text-primary;
            font-size: 22px;
            font-weight: 700;
            font-family: "monospace";
        }
    }
}
