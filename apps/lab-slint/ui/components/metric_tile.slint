import { Theme } from "../theme.slint";

export component MetricTile inherits Rectangle {
    in-out property <string> label;
    in-out property <int> value;
    in-out property <color> accent-color: Theme.lab-accent;

    background: Theme.surface;
    border-width: 1px;
    border-color: Theme.border;
    border-radius: 8px;
    min-height: 80px;

    HorizontalLayout {
        spacing: 0px;
        Rectangle {
            width: 4px;
            background: root.accent-color;
            border-radius: 2px;
        }
        VerticalLayout {
            padding: 14px;
            spacing: 6px;

            Text {
                text: root.label;
                color: Theme.text-secondary;
                font-size: 11px;
                font-weight: 600;
            }

            Text {
                text: "\{root.value}";
                color: Theme.text-primary;
                font-size: 24px;
                font-weight: 700;
            }
        }
    }
}
