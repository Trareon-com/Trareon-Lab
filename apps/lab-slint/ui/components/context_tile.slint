import { Theme } from "../theme.slint";

/// Acquire-style header context tile (Case / Coverage / Integrity / Warning).
export component ContextTile inherits Rectangle {
    in-out property <string> label;
    in-out property <string> value;
    in-out property <string> detail: "";
    in-out property <string> glyph: "";
    in-out property <bool> warn: false;
    in-out property <bool> ok: false;

    background: root.warn ? Theme.tile-warn-bg : Theme.surface;
    border-width: root.warn ? 0px : 1px;
    border-color: Theme.border;
    border-radius: 8px;
    min-height: 72px;
    horizontal-stretch: 1;

    HorizontalLayout {
        padding: 12px;
        spacing: 10px;

        if root.glyph != "": Text {
            text: root.glyph;
            color: root.warn ? Theme.tile-warn-fg
                : root.ok ? Theme.success
                : Theme.accent;
            font-size: 18px;
            vertical-alignment: center;
        }

        VerticalLayout {
            spacing: 4px;
            alignment: center;
            Text {
                text: root.label;
                color: root.warn ? Theme.tile-warn-fg : Theme.text-secondary;
                font-size: 10px;
                font-weight: 700;
                letter-spacing: 0.6px;
            }
            Text {
                text: root.value;
                color: root.warn ? Theme.tile-warn-fg : Theme.text-primary;
                font-size: 13px;
                font-weight: 700;
                overflow: elide;
            }
            if root.detail != "": Text {
                text: root.detail;
                color: root.warn ? Theme.tile-warn-fg : Theme.text-secondary;
                font-size: 11px;
                font-weight: root.ok ? 600 : 500;
                overflow: elide;
            }
        }
    }
}
