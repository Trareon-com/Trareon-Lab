import { Theme } from "../theme.slint";

export component StatusBadge inherits Rectangle {
    in-out property <string> label;
    // neutral | ok | warn | danger | info
    in-out property <string> kind: "neutral";

    border-radius: 4px;
    height: 22px;
    border-width: kind == "neutral" ? 1px : 0px;
    border-color: Theme.border;
    background: kind == "ok" ? Theme.success
        : kind == "warn" ? Theme.warning
        : kind == "danger" ? Theme.danger
        : kind == "info" ? Theme.info
        : Theme.surface-raised;
    horizontal-stretch: 0;
    vertical-stretch: 0;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        Text {
            text: root.label;
            color: kind == "warn" ? #1A1400
                : kind == "neutral" ? Theme.text-secondary
                : Theme.on-accent;
            font-size: 10px;
            font-weight: 700;
            vertical-alignment: center;
        }
    }
}
