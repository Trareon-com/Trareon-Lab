import { Theme } from "../theme.slint";

export component StatusBadge inherits Rectangle {
    in-out property <string> label;
    // neutral | ok | warn | danger | info
    in-out property <string> kind: "neutral";

    border-radius: 6px;
    height: 20px;
    background: kind == "ok" ? Theme.success-bg
        : kind == "warn" ? Theme.warning-bg
        : kind == "danger" ? Theme.danger-bg
        : kind == "info" ? Theme.info-bg
        : Theme.accent-muted;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 8px;
        Text {
            text: root.label;
            color: kind == "ok" ? Theme.success
                : kind == "warn" ? Theme.warning
                : kind == "danger" ? Theme.danger
                : kind == "info" ? Theme.info
                : Theme.accent;
            font-size: 10px;
            font-weight: 700;
            vertical-alignment: center;
        }
    }
}

