import { Theme } from "../theme.slint";
import { LabButton } from "lab_button.slint";

export component EmptyState inherits Rectangle {
    in-out property <string> title;
    in-out property <string> body;
    in-out property <bool> show-cta: false;
    in-out property <string> cta-label: "";
    callback cta-clicked();

    background: transparent;
    vertical-stretch: 1;
    horizontal-stretch: 1;

    VerticalLayout {
        alignment: center;
        spacing: 10px;
        padding: 40px;

        Rectangle {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.border;
            background: Theme.surface;
            HorizontalLayout {
                alignment: center;
                Text {
                    text: "◇";
                    color: Theme.accent;
                    font-size: 16px;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                }
            }
        }

        Text {
            text: root.title;
            color: Theme.text-primary;
            font-size: 15px;
            font-weight: 600;
            horizontal-alignment: center;
            wrap: word-wrap;
        }

        Text {
            text: root.body;
            color: Theme.text-secondary;
            font-size: 13px;
            horizontal-alignment: center;
            wrap: word-wrap;
        }

        if root.show-cta: HorizontalLayout {
            alignment: center;
            padding-top: 10px;
            LabButton {
                primary: true;
                label: root.cta-label;
                clicked => {
                    root.cta-clicked();
                }
            }
        }
    }
}
