import { Theme } from "theme.slint";
import { Strings } from "strings.slint";
import { CommandPalette } from "components/command_palette.slint";
import { DisclosureBanner } from "components/disclosure_banner.slint";
import { LabHeader } from "components/lab_header.slint";
import { LabSidebar } from "components/lab_sidebar.slint";
import { LabSafetyStrip } from "components/lab_safety_strip.slint";
import { LabStatusBar } from "components/lab_status_bar.slint";
import { InspectorPanel } from "components/inspector_panel.slint";
import { CaseScreen } from "screens/case_screen.slint";
import { EvidenceScreen } from "screens/evidence_screen.slint";
import { SearchScreen } from "screens/search_screen.slint";
import { TimelineScreen } from "screens/timeline_screen.slint";
import { BookmarksScreen } from "screens/bookmarks_screen.slint";
import { ReportScreen } from "screens/report_screen.slint";
import { PlaceholderScreen } from "screens/placeholder_screen.slint";
import { RunsScreen } from "screens/runs_screen.slint";
import { QuickVerifyScreen } from "screens/quick_verify_screen.slint";
import { HexScreen } from "screens/hex_screen.slint";
import { ArtifactsScreen } from "screens/artifacts_screen.slint";
import { GraphScreen } from "screens/graph_screen.slint";
import { TransferScreen } from "screens/transfer_screen.slint";
import { CapabilitiesScreen } from "screens/capabilities_screen.slint";
import { AboutScreen } from "screens/about_screen.slint";

export component AppWindow inherits Window {
    title: Strings.brand;
    preferred-width: 1280px;
    preferred-height: 800px;
    min-width: Theme.window-min-w;
    min-height: Theme.window-min-h;
    background: Theme.canvas;
    default-font-family: "Inter";
    default-font-size: 13px;

    in-out property <string> case-title: "(no case)";
    in-out property <string> case-state-label: "created";
    in-out property <int> evidence-count: 0;
    in-out property <int> coverage-count: 0;
    in-out property <int> bookmark-count: 0;
    in-out property <bool> open-case-focused: true;
    in-out property <string> active-screen: "Case";
    in-out property <string> about-line: "";
    in-out property <string> version-line: "Trareon Lab";
    in-out property <bool> dark-mode: false;
    in-out property <string> locale: "en";
    in-out property <string> footer-clock: "";
    in-out property <string> last-action: "";

    in-out property <bool> nav-collapsed: false;
    in-out property <bool> inspector-open: false;
    in-out property <bool> log-open: false;
    in-out property <bool> palette-open: false;
    in-out property <bool> cheatsheet-open: false;
    in-out property <string> inspector-tab: "properties";
    in-out property <bool> layout-compact: false;
    in-out property <bool> nav-expanded: false;
    in-out property <bool> inspector-as-side: false;
    in-out property <bool> inspector-as-overlay: false;
    in-out property <[string]> carve-hit-lines: [];
    in-out property <[string]> quick-verify-meta-lines: [];
    in-out property <[string]> quick-verify-timeline-lines: [];

    in-out property <[string]> evidence-names: [];
    in-out property <[string]> evidence-paths: [];
    in-out property <[string]> evidence-sizes: [];
    in-out property <[string]> evidence-designations: [];
    in-out property <[bool]> evidence-deleted: [];
    in-out property <[string]> evidence-integrity: [];
    in-out property <int> selected-file-index: -1;
    in-out property <string> evidence-filter: "";

    in-out property <string> search-query: "";
    in-out property <[string]> search-results: [];
    in-out property <[string]> artifact-kinds: [];
    in-out property <[string]> artifact-summaries: [];
    in-out property <[string]> artifact-provenances: [];
    in-out property <bool> search-attempted: false;
    in-out property <string> search-coverage-label: "";
    in-out property <[string]> yara-hit-lines: [];
    in-out property <[string]> hashset-hit-lines: [];
    in-out property <string> hashset-pin: "";
    in-out property <int> selected-search-index: -1;

    in-out property <[string]> timeline-labels: [];
    in-out property <string> timeline-tz: "UTC";
    in-out property <string> timeline-filter: "";
    in-out property <[string]> finding-claims: [];
    in-out property <[string]> finding-uuids: [];
    in-out property <string> report-state: "draft";
    in-out property <[string]> activity-lines: [];
    in-out property <[string]> exception-lines: [];
    in-out property <[string]> run-lines: [];
    in-out property <[string]> log-lines: [];
    in-out property <float> progress-ratio: 0.0;
    in-out property <string> progress-stage: "";
    in-out property <string> progress-message: "";
    in-out property <bool> progress-visible: false;

    in-out property <string> disclosure-line: "UNSIGNED — Lab use only · NOT court-ready · NOT ISO-certified";
    in-out property <string> coverage-status-label: "Not Run";
    in-out property <bool> report-finalizable: false;
    in-out property <[string]> report-blockers: [];
    in-out property <string> export-status: "";
    in-out property <[string]> export-format-labels: [];
    in-out property <int> selected-export-format: 0;
    in-out property <string> transfer-status: "";
    in-out property <string> transfer-trust-label: "";
    in-out property <int> list-total: 0;
    in-out property <int> list-offset: 0;
    in-out property <int> list-page-size: 200;
    in-out property <[string]> recent-case-titles: [];
    in-out property <[string]> recent-case-labels: [];
    in-out property <bool> prefs-open: false;
    in-out property <bool> reduce-motion: false;
    in-out property <string> prefs-last-case: "";
    in-out property <string> hex-status: "";
    in-out property <[string]> hex-lines: [];
    in-out property <[string]> tree-labels: [];
    in-out property <[int]> tree-depths: [];
    in-out property <[string]> tree-kinds: [];
    in-out property <[int]> tree-file-index: [];
    in-out property <[string]> graph-edges: [];
    in-out property <[string]> capability-ids: [];
    in-out property <[string]> capability-statuses: [];
    in-out property <[string]> capability-notes: [];

    in-out property <[string]> palette-commands: [];
    in-out property <string> palette-filter: "";
    in-out property <string> placeholder-title: "";
    in-out property <string> placeholder-body: "";

    in-out property <string> inspector-title: "";
    in-out property <string> inspector-path: "";
    in-out property <string> inspector-size: "";
    in-out property <string> inspector-designation: "";
    in-out property <string> inspector-integrity: "";
    in-out property <bool> inspector-deleted: false;
    in-out property <bool> inspector-tagged: false;

    property <bool> show-placeholder:
        root.active-screen == "SecondMethod"
        || root.active-screen == "PT"
        || root.active-screen == "Hypotheses";

    property <length> log-height: Theme.log-overlay-height;

    callback open-case-clicked();
    callback focus-open-case();
    callback navigate(string);
    callback import-evidence-clicked();
    callback cancel-progress-clicked();
    callback theme-toggled(bool);
    callback locale-toggled(string);
    callback search-submitted();
    callback evidence-row-selected(int);
    callback bookmark-selection-clicked();
    callback find-related-clicked();
    callback header-search-clicked();
    callback palette-filter-changed(string);
    callback palette-command-activated(string);
    callback palette-dismissed();
    callback toggle-inspector-clicked();
    callback toggle-log-clicked();
    callback toggle-nav-clicked();
    callback export-clicked();
    callback transfer-export-clicked();
    callback transfer-verify-clicked();
    callback import-timeline-clicked();
    callback shortcut-key(string);
    callback quick-verify-clicked();
    callback load-demo-clicked();
    callback run-carving-clicked();
    callback discard-ephemeral-clicked();
    callback inspector-tab-changed(string);
    callback hex-prev-clicked();
    callback hex-next-clicked();
    callback hex-popout-clicked();
    callback page-prev-clicked();
    callback page-next-clicked();
    callback copy-path-clicked();
    callback search-row-selected(int);
    callback export-format-selected(int);
    callback recent-case-clicked(int);
    callback timeline-filter-changed(string);
    callback prefs-toggled();
    callback reduce-motion-toggled(bool);

    changed dark-mode => { Theme.apply(dark-mode); }
    changed locale => { Strings.locale = locale; }
    changed reduce-motion => { Theme.reduce-motion = reduce-motion; }

    init => {
        Theme.apply(dark-mode);
        Strings.locale = locale;
        Theme.reduce-motion = reduce-motion;
    }

    focus-open-case => { open-case-focused = true; }

    property <int> workflow-stage: (case-title == "" || case-title == "(no case)") ? 1
        : evidence-count <= 0 ? 2
        : bookmark-count > 0 ? (report-finalizable ? 5 : 4)
        : 3;

    root-container := Rectangle {
        width: 100%;
        height: 100%;
        background: Theme.canvas;

        VerticalLayout {
            spacing: 0px;

            DisclosureBanner { line: root.disclosure-line; }

            LabHeader {
                case-title: root.case-title;
                case-state-label: root.case-state-label;
                compact: root.layout-compact;
                dark-mode <=> root.dark-mode;
                locale <=> root.locale;
                clock: root.footer-clock;
                palette-clicked => {
                    root.header-search-clicked();
                    root.shortcut-key("/");
                }
                case-clicked => { root.navigate("Case"); }
                locale-toggled(l) => { root.locale-toggled(l); }
                theme-toggled(d) => { root.theme-toggled(d); }
            }

            HorizontalLayout {
                vertical-stretch: 1;

                LabSidebar {
                    active-key: root.active-screen;
                    expanded: root.nav-expanded;
                    version-line: root.version-line;
                    navigate-key(k) => { root.navigate(k); }
                }

                VerticalLayout {
                    horizontal-stretch: 1;
                    spacing: 0px;

                    LabSafetyStrip {
                        case-title: root.case-title;
                        coverage-label: root.coverage-status-label;
                        integrity-label: "SHA-256";
                        integrity-ok: true;
                        active-stage: root.workflow-stage;
                        case-clicked => { root.navigate("Case"); }
                        coverage-clicked => { root.navigate("Case"); }
                        stage-clicked(i) => {
                            if i == 1 {
                                root.navigate("Case");
                            } else if i == 2 {
                                root.navigate("Case");
                            } else if i == 3 {
                                root.navigate("Evidence");
                            } else if i == 4 {
                                root.navigate("Bookmarks");
                            } else {
                                root.navigate("Report");
                            }
                        }
                    }

                Rectangle {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;
                    min-width: 480px;
                    clip: true;
                    background: Theme.canvas;

                    Flickable {
                        width: 100%;
                        height: 100%;
                        viewport-width: parent.width;

                        Rectangle {
                            width: parent.width;
                            min-height: parent.height;

                            CaseScreen {
                                visible: root.active-screen == "Case";
                                width: 100%;
                                height: 100%;
                                case-title: root.case-title;
                                case-state-label: root.case-state-label;
                                evidence-count: root.evidence-count;
                                coverage-count: root.coverage-count;
                                bookmark-count: root.bookmark-count;
                                report-finalizable: root.report-finalizable;
                                activity-lines: root.activity-lines;
                                exception-lines: root.exception-lines;
                                recent-case-titles: root.recent-case-titles;
                                recent-case-labels: root.recent-case-labels;
                                open-case-clicked => { root.open-case-clicked(); }
                                import-evidence-clicked => { root.import-evidence-clicked(); }
                                quick-verify-clicked => { root.quick-verify-clicked(); }
                                load-demo-clicked => { root.load-demo-clicked(); }
                                navigate(s) => { root.navigate(s); }
                                recent-case-clicked(i) => { root.recent-case-clicked(i); }
                            }

                            EvidenceScreen {
                                visible: root.active-screen == "Evidence";
                                width: 100%;
                                height: 100%;
                                evidence-names: root.evidence-names;
                                evidence-paths: root.evidence-paths;
                                evidence-sizes: root.evidence-sizes;
                                evidence-designations: root.evidence-designations;
                                evidence-integrity: root.evidence-integrity;
                                evidence-deleted: root.evidence-deleted;
                                selected-file-index: root.selected-file-index;
                                filter-text <=> root.evidence-filter;
                                carve-hit-lines: root.carve-hit-lines;
                                list-total: root.list-total;
                                list-offset: root.list-offset;
                                list-page-size: root.list-page-size;
                                import-evidence-clicked => { root.import-evidence-clicked(); }
                                evidence-row-selected(i) => { root.evidence-row-selected(i); }
                                run-carving-clicked => { root.run-carving-clicked(); }
                                bookmark-clicked => { root.bookmark-selection-clicked(); }
                                open-hex-clicked => {
                                    root.inspector-tab-changed("hex");
                                    if !root.inspector-open {
                                        root.toggle-inspector-clicked();
                                    }
                                }
                                page-prev-clicked => { root.page-prev-clicked(); }
                                page-next-clicked => { root.page-next-clicked(); }
                                copy-path-clicked => { root.copy-path-clicked(); }
                            }

                            SearchScreen {
                                visible: root.active-screen == "Search";
                                width: 100%;
                                height: 100%;
                                search-query <=> root.search-query;
                                search-results: root.search-results;
                                artifact-kinds: root.artifact-kinds;
                                artifact-summaries: root.artifact-summaries;
                                artifact-provenances: root.artifact-provenances;
                                search-attempted <=> root.search-attempted;
                                search-coverage-label: root.search-coverage-label;
                                yara-hit-lines: root.yara-hit-lines;
                                hashset-hit-lines: root.hashset-hit-lines;
                                hashset-pin: root.hashset-pin;
                                selected-search-index <=> root.selected-search-index;
                                search-submitted => { root.search-submitted(); }
                                query-changed(q) => { root.search-query = q; }
                                open-in-evidence-clicked => { root.navigate("Evidence"); }
                                bookmark-hit-clicked => { root.bookmark-selection-clicked(); }
                                search-row-selected(i) => { root.search-row-selected(i); }
                            }

                            TimelineScreen {
                                visible: root.active-screen == "Timeline";
                                width: 100%;
                                height: 100%;
                                timeline-labels: root.timeline-labels;
                                timeline-tz: root.timeline-tz;
                                timeline-filter <=> root.timeline-filter;
                                jump-evidence-clicked => { root.navigate("Evidence"); }
                                bookmark-hit-clicked => { root.bookmark-selection-clicked(); }
                                import-timeline-clicked => { root.import-timeline-clicked(); }
                                filter-changed(q) => { root.timeline-filter-changed(q); }
                            }

                            BookmarksScreen {
                                visible: root.active-screen == "Bookmarks";
                                width: 100%;
                                height: 100%;
                                finding-claims: root.finding-claims;
                                finding-uuids: root.finding-uuids;
                                bookmark-count: root.bookmark-count;
                                navigate-report => { root.navigate("Report"); }
                                go-evidence-clicked => { root.navigate("Evidence"); }
                            }

                            ReportScreen {
                                visible: root.active-screen == "Report";
                                width: 100%;
                                height: 100%;
                                report-state: root.report-state;
                                finding-claims: root.finding-claims;
                                finding-uuids: root.finding-uuids;
                                about-line: root.about-line;
                                report-finalizable: root.report-finalizable;
                                report-blockers: root.report-blockers;
                                export-status: root.export-status;
                                export-format-labels: root.export-format-labels;
                                selected-export-format <=> root.selected-export-format;
                                export-clicked => { root.export-clicked(); }
                                transfer-export-clicked => { root.transfer-export-clicked(); }
                                export-format-selected(i) => { root.export-format-selected(i); }
                            }

                            RunsScreen {
                                visible: root.active-screen == "Runs";
                                width: 100%;
                                height: 100%;
                                run-lines: root.run-lines;
                            }

                            QuickVerifyScreen {
                                visible: root.active-screen == "QuickVerify";
                                width: 100%;
                                height: 100%;
                                meta-lines: root.quick-verify-meta-lines;
                                carve-lines: root.carve-hit-lines;
                                timeline-lines: root.quick-verify-timeline-lines;
                                pick-file-clicked => { root.quick-verify-clicked(); }
                                discard-clicked => { root.discard-ephemeral-clicked(); }
                            }

                            HexScreen {
                                visible: root.active-screen == "Hex";
                                width: 100%;
                                height: 100%;
                                hex-status: root.hex-status;
                                hex-lines: root.hex-lines;
                                has-selection: root.selected-file-index >= 0;
                                prev-clicked => { root.hex-prev-clicked(); }
                                next-clicked => { root.hex-next-clicked(); }
                                open-evidence-clicked => { root.navigate("Evidence"); }
                            }

                            ArtifactsScreen {
                                visible: root.active-screen == "Artifacts";
                                width: 100%;
                                height: 100%;
                                artifact-kinds: root.artifact-kinds;
                                artifact-summaries: root.artifact-summaries;
                                artifact-provenances: root.artifact-provenances;
                                go-search-clicked => { root.navigate("Search"); }
                            }

                            GraphScreen {
                                visible: root.active-screen == "Graph";
                                width: 100%;
                                height: 100%;
                                graph-edges: root.graph-edges;
                                go-evidence-clicked => { root.navigate("Evidence"); }
                            }

                            TransferScreen {
                                visible: root.active-screen == "Transfer";
                                width: 100%;
                                height: 100%;
                                transfer-status: root.transfer-status;
                                transfer-trust-label: root.transfer-trust-label;
                                export-clicked => { root.transfer-export-clicked(); }
                                verify-clicked => { root.transfer-verify-clicked(); }
                            }

                            CapabilitiesScreen {
                                visible: root.active-screen == "Capabilities";
                                width: 100%;
                                height: 100%;
                                capability-ids: root.capability-ids;
                                capability-statuses: root.capability-statuses;
                                capability-notes: root.capability-notes;
                            }

                            AboutScreen {
                                visible: root.active-screen == "About";
                                width: 100%;
                                height: 100%;
                                about-line: root.about-line;
                                version-line: root.version-line;
                                disclosure-line: root.disclosure-line;
                            }

                            PlaceholderScreen {
                                visible: root.show-placeholder;
                                width: 100%;
                                height: 100%;
                                title: root.placeholder-title;
                                body: root.placeholder-body;
                            }
                        }
                    }

                    // Log overlay (VS Code terminal pattern)
                    if root.log-open: Rectangle {
                        y: parent.height - root.log-height;
                        width: 100%;
                        height: root.log-height;
                        background: Theme.surface;
                        border-width: 1px;
                        border-color: Theme.border;
                        drop-shadow-blur: 12px;
                        drop-shadow-color: Theme.shadow;
                        drop-shadow-offset-y: -2px;
                        VerticalLayout {
                            padding: 10px;
                            spacing: 4px;
                            Text {
                                text: Strings.log-title;
                                color: Theme.text-secondary;
                                font-size: 11px;
                                font-weight: 800;
                                letter-spacing: 0.5px;
                            }
                            Flickable {
                                vertical-stretch: 1;
                                if root.log-lines.length == 0: Text {
                                    text: Strings.log-empty;
                                    color: Theme.text-secondary;
                                    font-size: 11px;
                                }
                                if root.log-lines.length > 0: VerticalLayout {
                                    for line in root.log-lines: Text {
                                        text: line;
                                        color: Theme.mono-fg;
                                        font-family: "monospace";
                                        font-size: 10px;
                                        overflow: elide;
                                    }
                                }
                            }
                        }
                    }

                    // Compact-width inspector overlay
                    if root.inspector-as-overlay: Rectangle {
                        x: parent.width - Theme.inspector-width;
                        width: Theme.inspector-width;
                        height: 100%;
                        InspectorPanel {
                            width: 100%;
                            height: 100%;
                            title: root.inspector-title;
                            path: root.inspector-path;
                            size-label: root.inspector-size;
                            designation-label: root.inspector-designation;
                            integrity-label: root.inspector-integrity;
                            deleted: root.inspector-deleted;
                            tagged: root.inspector-tagged;
                            has-selection: root.selected-file-index >= 0;
                            hex-status: root.hex-status;
                            hex-lines: root.hex-lines;
                            active-tab: root.inspector-tab;
                            bookmark-clicked => { root.bookmark-selection-clicked(); }
                            find-related-clicked => { root.find-related-clicked(); }
                            close-clicked => { root.toggle-inspector-clicked(); }
                            tab-changed(t) => { root.inspector-tab-changed(t); }
                            hex-prev-clicked => { root.hex-prev-clicked(); }
                            hex-next-clicked => { root.hex-next-clicked(); }
                            hex-popout-clicked => { root.hex-popout-clicked(); }
                        }
                    }
                }
                } // VerticalLayout: safety + body

                if root.inspector-as-side: InspectorPanel {
                    title: root.inspector-title;
                    path: root.inspector-path;
                    size-label: root.inspector-size;
                    designation-label: root.inspector-designation;
                    integrity-label: root.inspector-integrity;
                    deleted: root.inspector-deleted;
                    tagged: root.inspector-tagged;
                    has-selection: root.selected-file-index >= 0;
                    hex-status: root.hex-status;
                    hex-lines: root.hex-lines;
                    active-tab: root.inspector-tab;
                    bookmark-clicked => { root.bookmark-selection-clicked(); }
                    find-related-clicked => { root.find-related-clicked(); }
                    close-clicked => { root.toggle-inspector-clicked(); }
                    tab-changed(t) => { root.inspector-tab-changed(t); }
                    hex-prev-clicked => { root.hex-prev-clicked(); }
                    hex-next-clicked => { root.hex-next-clicked(); }
                    hex-popout-clicked => { root.hex-popout-clicked(); }
                }
            }

            LabStatusBar {
                evidence-count: root.evidence-count;
                coverage-count: root.coverage-count;
                bookmark-count: root.bookmark-count;
                last-action: root.last-action;
                clock: root.footer-clock;
                progress-visible: root.progress-visible;
                progress-ratio: root.progress-ratio;
                progress-stage: root.progress-stage;
                progress-message: root.progress-message;
                nav-expanded: root.nav-expanded;
                log-open: root.log-open;
                inspector-open: root.inspector-open;
                toggle-nav-clicked => { root.toggle-nav-clicked(); }
                toggle-log-clicked => { root.toggle-log-clicked(); }
                toggle-inspector-clicked => { root.toggle-inspector-clicked(); }
                cancel-progress-clicked => { root.cancel-progress-clicked(); }
                prefs-clicked => { root.prefs-toggled(); }
            }
        }

        if root.palette-open: CommandPalette {
            width: parent.width;
            height: parent.height;
            filter <=> root.palette-filter;
            commands: root.palette-commands;
            filter-changed(s) => { root.palette-filter-changed(s); }
            command-activated(cmd) => { root.palette-command-activated(cmd); }
            dismissed => { root.palette-dismissed(); }
        }

        if root.cheatsheet-open: Rectangle {
            width: parent.width;
            height: parent.height;
            background: #00000066;
            TouchArea { clicked => { root.cheatsheet-open = false; } }
            Rectangle {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                width: min(480px, parent.width - 48px);
                background: Theme.surface;
                border-width: 1px;
                border-color: Theme.border;
                border-radius: Theme.panel-radius;
                drop-shadow-blur: 16px;
                drop-shadow-color: Theme.shadow;
                VerticalLayout {
                    padding: 16px;
                    spacing: 10px;
                    Text {
                        text: Strings.cheatsheet-title;
                        color: Theme.text-secondary;
                        font-size: 11px;
                        font-weight: 800;
                        letter-spacing: 0.5px;
                    }
                    Text {
                        text: Strings.cheatsheet-body;
                        color: Theme.text-primary;
                        font-size: 13px;
                        wrap: word-wrap;
                    }
                }
            }
        }

        if root.prefs-open: Rectangle {
            width: parent.width;
            height: parent.height;
            background: #00000066;
            TouchArea { clicked => { root.prefs-toggled(); } }
            Rectangle {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                width: min(400px, parent.width - 48px);
                background: Theme.surface;
                border-width: 1px;
                border-color: Theme.border;
                border-radius: Theme.panel-radius;
                drop-shadow-blur: 16px;
                drop-shadow-color: Theme.shadow;
                VerticalLayout {
                    padding: 16px;
                    spacing: 12px;
                    Text {
                        text: Strings.prefs;
                        color: Theme.text-secondary;
                        font-size: 11px;
                        font-weight: 800;
                        letter-spacing: 0.5px;
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        Text {
                            text: root.dark-mode ? Strings.theme-dark : Strings.theme-light;
                            color: Theme.text-primary;
                            font-size: 12px;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                        TouchArea {
                            width: 72px;
                            height: 28px;
                            clicked => { root.theme-toggled(!root.dark-mode); }
                            Rectangle {
                                background: Theme.accent-muted;
                                border-radius: Theme.chip-radius;
                                border-width: 1px;
                                border-color: Theme.accent;
                                Text {
                                    width: 100%;
                                    height: 100%;
                                    text: root.dark-mode ? Strings.theme-light : Strings.theme-dark;
                                    color: Theme.accent;
                                    font-size: 11px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        Text {
                            text: Strings.lang-en + " / " + Strings.lang-id;
                            color: Theme.text-primary;
                            font-size: 12px;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                        TouchArea {
                            width: 72px;
                            height: 28px;
                            clicked => {
                                root.locale-toggled(root.locale == "en" ? "id" : "en");
                            }
                            Rectangle {
                                background: Theme.surface-raised;
                                border-radius: Theme.chip-radius;
                                border-width: 1px;
                                border-color: Theme.border;
                                Text {
                                    width: 100%;
                                    height: 100%;
                                    text: root.locale == "en" ? Strings.lang-id : Strings.lang-en;
                                    color: Theme.text-primary;
                                    font-size: 11px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                    HorizontalLayout {
                        spacing: 8px;
                        Text {
                            text: Strings.reduce-motion;
                            color: Theme.text-primary;
                            font-size: 12px;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                        TouchArea {
                            width: 72px;
                            height: 28px;
                            clicked => { root.reduce-motion-toggled(!root.reduce-motion); }
                            Rectangle {
                                background: root.reduce-motion ? Theme.accent-muted : Theme.surface-raised;
                                border-radius: Theme.chip-radius;
                                border-width: 1px;
                                border-color: root.reduce-motion ? Theme.accent : Theme.border;
                                Text {
                                    width: 100%;
                                    height: 100%;
                                    text: root.reduce-motion ? "ON" : "OFF";
                                    color: root.reduce-motion ? Theme.accent : Theme.text-secondary;
                                    font-size: 11px;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                    Text {
                        text: Strings.prefs-last-case;
                        color: Theme.text-secondary;
                        font-size: 11px;
                        font-weight: 700;
                    }
                    Text {
                        text: root.prefs-last-case == "" ? "—" : root.prefs-last-case;
                        color: Theme.mono-fg;
                        font-family: "monospace";
                        font-size: 11px;
                        wrap: word-wrap;
                    }
                }
            }
        }
    }
}
