// Trareon Forensic Family tokens — copper brand accent; teal = lab-accent.

export global Theme {
    in-out property <bool> dark: false;
    in-out property <color> canvas: #E8EDF2;
    in-out property <color> surface: #FFFFFF;
    in-out property <color> surface-raised: #F0F3F7;
    in-out property <color> border: #D0D8E0;
    in-out property <color> text-primary: #121820;
    in-out property <color> text-secondary: #5A6A78;
    in-out property <color> accent: #A86B3E;
    in-out property <color> accent-muted: #E8D5C4;
    in-out property <color> lab-accent: #2F7F75;
    in-out property <color> danger: #B04040;
    in-out property <color> warning: #C9A227;
    in-out property <color> success: #4F9F6A;
    in-out property <color> info: #5B8FD9;
    in-out property <color> row-hover: #F3EAE3;
    in-out property <color> nav-active-bar: #A86B3E;
    in-out property <color> mono-fg: #3A4254;
    in-out property <color> status-bar-bg: #F0F3F7;
    in-out property <color> on-accent: #FFFFFF;
    in-out property <color> focus-ring: #A86B3E;

    public function apply(is-dark: bool) {
        dark = is-dark;
        if is-dark {
            canvas = #080C10;
            surface = #121A22;
            surface-raised = #1A2430;
            border = #2A3848;
            text-primary = #EEF3F7;
            text-secondary = #93A3B4;
            accent = #D09262;
            accent-muted = #2A1F16;
            lab-accent = #3D9B8F;
            danger = #D16B6B;
            warning = #C9A227;
            success = #4F9F6A;
            info = #5B8FD9;
            row-hover = #22303B;
            nav-active-bar = #D09262;
            mono-fg = #B8C0D0;
            status-bar-bg = #0E151C;
            on-accent = #F4FFFC;
            focus-ring = #D09262;
        } else {
            canvas = #E8EDF2;
            surface = #FFFFFF;
            surface-raised = #F0F3F7;
            border = #D0D8E0;
            text-primary = #121820;
            text-secondary = #5A6A78;
            accent = #A86B3E;
            accent-muted = #E8D5C4;
            lab-accent = #2F7F75;
            danger = #B04040;
            warning = #C9A227;
            success = #4F9F6A;
            info = #5B8FD9;
            row-hover = #F3EAE3;
            nav-active-bar = #A86B3E;
            mono-fg = #3A4254;
            status-bar-bg = #F0F3F7;
            on-accent = #FFFFFF;
            focus-ring = #A86B3E;
        }
    }
}
