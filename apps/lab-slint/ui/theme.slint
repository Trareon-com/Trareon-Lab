// Trareon Lab — ASCII shell tokens (Acquire-family copper SoT).
// Light default; dark via header toggle. Font: bundled Inter.

import "../assets/fonts/Inter-Regular.ttf";
import "../assets/fonts/Inter-Medium.ttf";
import "../assets/fonts/Inter-SemiBold.ttf";
import "../assets/fonts/Inter-Bold.ttf";

export global Theme {
    // Geometry (Acquire ASCII chrome; preferred 1280×800)
    out property <length> disclosure-height: 26px;
    out property <length> header-height: 48px;
    out property <length> sidebar-rail-width: 56px;
    out property <length> sidebar-width: 188px;
    out property <length> safety-height: 40px;
    out property <length> inspector-width: 280px;
    out property <length> status-height: 30px;
    out property <length> log-overlay-height: 160px;
    out property <length> row-height: 26px;
    out property <length> chrome-pad: 8px;
    out property <length> main-pad: 16px;
    out property <length> panel-radius: 8px;
    out property <length> chip-radius: 5px;
    out property <length> nav-row-height: 38px;
    out property <length> window-min-w: 920px;
    out property <length> window-min-h: 680px;
    // Legacy aliases
    out property <length> footer-height: 30px;

    in-out property <bool> dark: false;
    in-out property <color> canvas: #F4F6F8;
    in-out property <color> surface: #FFFFFF;
    in-out property <color> surface-raised: #EEF1F4;
    in-out property <color> border: #D8DDE3;
    in-out property <color> text-primary: #1E2A36;
    in-out property <color> text-secondary: #5F6F7F;
    in-out property <color> accent: #AF622E;
    in-out property <color> accent-hover: #B85A28;
    in-out property <color> accent-muted: #FFF4EC;
    in-out property <color> lab-accent: #0D9488;
    in-out property <color> danger: #B04040;
    in-out property <color> danger-bg: #F8EAEA;
    in-out property <color> warning: #AF622E;
    in-out property <color> warning-bg: #FFF2E8;
    in-out property <color> success: #2F855A;
    in-out property <color> success-bg: #E6F2EA;
    in-out property <color> info: #5F6F7F;
    in-out property <color> info-bg: #F0F3F6;
    in-out property <color> row-hover: #F0F3F6;
    in-out property <color> nav-active-bar: #AF622E;
    in-out property <color> mono-fg: #1E2A36;
    in-out property <color> status-bar-bg: #EAEFF3;
    in-out property <color> on-accent: #FFFFFF;
    in-out property <color> focus-ring: #C96A38;
    in-out property <color> sidebar-bg: #FFFFFF;
    in-out property <color> tile-warn-bg: #FFF2E8;
    in-out property <color> tile-warn-fg: #AF622E;
    in-out property <color> shadow: #00000018;
    in-out property <color> icon-muted: #8A94A0;
    in-out property <color> icon-active: #AF622E;
    out property <string> font-ui: "Inter";
    // Letter-spacing for Acquire-like display labels (Inter fallback; no Avenir host dep).
    out property <float> tracking-label: 0.5;
    in-out property <bool> reduce-motion: false;

    public function apply(is-dark: bool) {
        dark = is-dark;
        if is-dark {
            canvas = #0C1014;
            surface = #161E26;
            surface-raised = #1C2630;
            border = #2A3644;
            text-primary = #E8EEF4;
            text-secondary = #8B9AAB;
            accent = #C4845A;
            accent-hover = #D09060;
            accent-muted = #1A2430;
            lab-accent = #14B8A6;
            danger = #D16B6B;
            danger-bg = #3A1E1E;
            warning = #C4845A;
            warning-bg = #3A2A20;
            success = #B7D4BE;
            success-bg = #2E4A3C;
            info = #8B9AAB;
            info-bg = #1A2430;
            row-hover = #1C2630;
            nav-active-bar = #C4845A;
            mono-fg = #E8EEF4;
            status-bar-bg = #0E141A;
            on-accent = #140E0A;
            focus-ring = #E0A070;
            sidebar-bg = #121820;
            tile-warn-bg = #3A2A20;
            tile-warn-fg = #E0A070;
            shadow = #00000055;
            icon-muted = #5C6B7A;
            icon-active = #C4845A;
        } else {
            canvas = #F4F6F8;
            surface = #FFFFFF;
            surface-raised = #EEF1F4;
            border = #D8DDE3;
            text-primary = #1E2A36;
            text-secondary = #5F6F7F;
            accent = #AF622E;
            accent-hover = #B85A28;
            accent-muted = #FFF4EC;
            lab-accent = #0D9488;
            danger = #B04040;
            danger-bg = #F8EAEA;
            warning = #AF622E;
            warning-bg = #FFF2E8;
            success = #2F855A;
            success-bg = #E6F2EA;
            info = #5F6F7F;
            info-bg = #F0F3F6;
            row-hover = #F0F3F6;
            nav-active-bar = #AF622E;
            mono-fg = #1E2A36;
            status-bar-bg = #EAEFF3;
            on-accent = #FFFFFF;
            focus-ring = #C96A38;
            sidebar-bg = #FFFFFF;
            tile-warn-bg = #FFF2E8;
            tile-warn-fg = #AF622E;
            shadow = #00000018;
            icon-muted = #8A94A0;
            icon-active = #AF622E;
        }
    }
}
