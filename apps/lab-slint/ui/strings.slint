// Chrome copy for EN / ID. Display strings live here only.

export global Strings {
    in-out property <string> locale: "en";
    out property <bool> is-id: locale == "id";

    out property <string> brand: "Trareon Lab";
    out property <string> welcome-headline: is-id ? "Laboratorium forensik offline" : "Offline forensic workstation";
    out property <string> welcome-body: is-id
        ? "Buka folder kasus untuk membuat basis data lokal, mengimpor citra mentah, mencari path/hash, dan menandai temuan."
        : "Open a case folder to create a local database, import raw images, search paths/hashes, and bookmark findings.";
    out property <string> welcome-meta: is-id
        ? "case.sqlite · index.sqlite · offline · local-first"
        : "case.sqlite · index.sqlite · offline · local-first";
    out property <string> idle-state: is-id ? "siaga" : "idle";
    out property <string> nav-group-case: is-id ? "KASUS" : "CASE";
    out property <string> nav-group-examine: is-id ? "PERIKSA" : "EXAMINE";
    out property <string> nav-group-work: is-id ? "HASIL KERJA" : "WORK PRODUCT";
    out property <string> nav-case: is-id ? "Beranda" : "Home";
    out property <string> nav-evidence: is-id ? "Bukti" : "Evidence";
    out property <string> nav-search: is-id ? "Cari" : "Search";
    out property <string> nav-timeline: is-id ? "Linimasa" : "Timeline";
    out property <string> nav-bookmarks: is-id ? "Markah" : "Bookmarks";
    out property <string> nav-report: is-id ? "Laporan" : "Report";
    out property <string> open-case: is-id ? "Buka Kasus" : "Open Case";
    out property <string> import-evidence: is-id ? "Impor Bukti" : "Import Evidence";
    out property <string> browse-evidence: is-id ? "Jelajahi Bukti" : "Browse Evidence";
    out property <string> theme-dark: is-id ? "Gelap" : "Dark";
    out property <string> theme-light: is-id ? "Terang" : "Light";
    out property <string> lang-en: "EN";
    out property <string> lang-id: "ID";
    out property <string> prefs: is-id ? "Preferensi" : "Preferences";
    out property <string> case-overview: is-id ? "Identitas Kasus" : "Case Identity";
    out property <string> next-action: is-id ? "Langkah Berikutnya" : "Next Action";
    out property <string> next-open: is-id ? "Buka atau buat kasus untuk memulai." : "Open or create a case to begin.";
    out property <string> next-import: is-id ? "Impor bukti agar pemeriksaan bisa dimulai." : "Import evidence so examination can begin.";
    out property <string> next-examine: is-id ? "Bukti siap. Mulai dari jelajah berkas, pencarian, atau linimasa." : "Evidence is ready. Start from files, search, or timeline.";
    out property <string> next-report: is-id ? "Ada markah. Susun klaim ke dalam laporan." : "Bookmarks exist. Fold claims into the report.";
    out property <string> activity: is-id ? "Aktivitas Terkini" : "Recent Activity";
    out property <string> activity-empty: is-id ? "Belum ada aktivitas pada kasus ini." : "No activity recorded for this case yet.";
    out property <string> examine-now: is-id ? "Periksa Sekarang" : "Examine Now";
    out property <string> evidence-overview: is-id ? "Cakupan" : "Coverage";
    out property <string> places-to-start: is-id ? "Pintasan Periksa" : "Examine Shortcuts";
    out property <string> status-evidence: is-id ? "Bukti" : "Evidence";
    out property <string> status-coverage: is-id ? "Cakupan" : "Coverage";
    out property <string> status-bookmarks: is-id ? "Markah" : "Bookmarks";
    out property <string> shortcuts-hint: is-id ? "/ cari · b markah · Esc batal" : "/ search · b bookmark · Esc clear";
    out property <string> header-search-hint: is-id ? "Cari path / hash  (/)" : "Search path / hash  (/)";
    out property <string> empty-no-case: is-id ? "Belum ada kasus" : "No case open";
    out property <string> empty-no-evidence: is-id ? "Belum ada bukti" : "No evidence imported";
    out property <string> empty-no-selection: is-id ? "Pilih berkas di daftar" : "Select a file from the list";
    out property <string> empty-no-search: is-id ? "Tidak ada hasil" : "No search results";
    out property <string> empty-no-timeline: is-id ? "Tidak ada peristiwa" : "No timeline events";
    out property <string> empty-no-bookmarks: is-id ? "Belum ada markah" : "No bookmarks yet";
    out property <string> empty-no-findings: is-id ? "Belum ada temuan" : "No findings yet";
    out property <string> empty-hint-case: is-id ? "Buka kasus untuk memulai pemeriksaan." : "Open a case to begin examination.";
    out property <string> empty-hint-evidence: is-id ? "Impor bukti untuk mengisi daftar berkas." : "Import evidence to populate the file list.";
    out property <string> empty-hint-search: is-id ? "Cari path, nama, atau hash yang sudah terindeks dari bukti yang diimpor." : "Search indexed paths, names, or hashes from imported evidence.";
    out property <string> empty-hint-timeline: is-id ? "Linimasa artefak penuh belum di v1 — gunakan Cari untuk path/hash yang terindeks." : "Full artifact timeline is not in v1 — use Search for indexed paths/hashes.";
    out property <string> empty-hint-bookmarks: is-id ? "Tandai temuan penting saat meninjau bukti." : "Bookmark important findings while reviewing evidence.";
    out property <string> empty-hint-report: is-id ? "Temuan terikat dari markah akan muncul di sini. Ekspor PDF belum di v1." : "Bound findings from bookmarks will appear here. PDF export is not in v1.";
    out property <string> search-placeholder: is-id ? "Cari path / nama / hash…" : "Search path / name / hash…";
    out property <string> search-action: is-id ? "Cari" : "Search";
    out property <string> hits: is-id ? "hasil" : "hits";
    out property <string> export-soon: is-id ? "Ekspor PDF — belum di v1" : "PDF export — not in v1";
    out property <string> report-state: is-id ? "Status laporan" : "Report state";
    out property <string> col-name: is-id ? "Nama" : "Name";
    out property <string> col-size: is-id ? "Ukuran" : "Size";
    out property <string> col-path: is-id ? "Jalur" : "Path";
    out property <string> col-kind: is-id ? "Jenis" : "Kind";
    out property <string> col-summary: is-id ? "Ringkasan" : "Summary";
    out property <string> col-provenance: is-id ? "Provenans" : "Provenance";
    out property <string> col-claim: is-id ? "Klaim" : "Claim";
    out property <string> col-event: is-id ? "Peristiwa" : "Event";
    out property <string> deleted: is-id ? "terhapus" : "deleted";
    out property <string> about-prefix: is-id ? "Tentang & pengungkapan" : "About & disclosure";
    out property <string> filter-placeholder: is-id ? "Filter nama / jalur…" : "Filter name / path…";
    out property <string> filter-stub: is-id ? "Filter rentang (segera)" : "Range filter (soon)";
    out property <string> go-evidence: is-id ? "Jelajahi bukti" : "Browse evidence";
    out property <string> go-search: is-id ? "Cari path / hash" : "Search path / hash";
    out property <string> go-timeline: is-id ? "Buka linimasa" : "Open timeline";
    out property <string> go-bookmarks: is-id ? "Lihat markah" : "View bookmarks";
    out property <string> go-report: is-id ? "Siapkan laporan" : "Prepare report";
    out property <string> detail-title: is-id ? "Detail berkas" : "File detail";
    out property <string> files-title: is-id ? "Berkas bukti" : "Evidence files";
    out property <string> results-title: is-id ? "Hasil" : "Results";
    out property <string> add-bookmark: is-id ? "Tambah Markah" : "Add Bookmark";
    out property <string> find-related: is-id ? "Cari Terkait" : "Find Related";
    out property <string> open-in-evidence: is-id ? "Buka di Bukti" : "Open in Evidence";
    out property <string> jump-evidence: is-id ? "Lompat ke Bukti" : "Jump to Evidence";
    out property <string> queue-for-report: is-id ? "Antrean untuk laporan" : "Queue for report";
    out property <string> work-product-hint: is-id ? "Markah di sini menjadi bahan klaim laporan." : "Bookmarks here become report claim material.";
}
