{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://trareon.com/schemas/transfer-package.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "transfer_uuid",
    "source_case_uuid",
    "created_at_utc",
    "destination",
    "purpose",
    "authority_note",
    "selected_bookmark_digests",
    "result",
    "signature"
  ],
  "properties": {
    "schema_version": { "const": "transfer-package-1" },
    "transfer_uuid": { "type": "string", "format": "uuid" },
    "source_case_uuid": { "type": "string", "format": "uuid" },
    "created_at_utc": { "type": "string", "format": "date-time" },
    "destination": { "type": "string", "minLength": 1 },
    "purpose": { "type": "string", "minLength": 1 },
    "authority_note": { "type": "string", "minLength": 1 },
    "selected_bookmark_digests": {
      "type": "array",
      "items": { "type": "string", "minLength": 64, "maxLength": 64 },
      "minItems": 1
    },
    "result": {
      "enum": ["export_ready", "imported", "rejected"]
    },
    "signature": {
      "type": "object",
      "required": [
        "algorithm",
        "key_id",
        "payload_digest",
        "signature",
        "trust_state"
      ],
      "properties": {
        "algorithm": { "const": "Ed25519" },
        "key_id": { "type": "string", "minLength": 1 },
        "payload_digest": { "type": "string", "minLength": 64 },
        "signature": { "type": "string", "minLength": 1 },
        "trust_state": {
          "enum": [
            "VALID_TRUSTED",
            "VALID_UNTRUSTED",
            "INVALID",
            "EXPIRED_OR_REVOKED",
            "NOT_SIGNED",
            "NOT_CHECKED"
          ]
        }
      }
    }
  },
  "additionalProperties": true
}
